@page "/admin"
@using GestorGanadero.Frontend.Services
@using GestorGanadero.Grpc.V1
@inject LivestockService.LivestockServiceClient Client
@inject AppState State
@implements IDisposable

<div class="module-header">
    <h1>Administración de Catálogos</h1>
    <div class="admin-tabs">
        <button class="@(_subModule == "fields" ? "active" : "")" @onclick='@(() => SetSubModule("fields"))'>Establecimientos</button>
        <button class="@(_subModule == "activities" ? "active" : "")" @onclick='@(() => SetSubModule("activities"))'>Actividades</button>
        <button class="@(_subModule == "categories" ? "active" : "")" @onclick='@(() => SetSubModule("categories"))'>Categorías</button>
        <button class="@(_subModule == "users" ? "active" : "")" @onclick='@(() => SetSubModule("users"))'>Usuarios</button>
    </div>
</div>

<div class="admin-layout">
    <div class="master-list">
        <div class="list-header">
            <h3>Lista de @_subModuleDisplay</h3>
            <button class="btn-primary" @onclick="AddNew">＋ Nuevo</button>
        </div>
        <div class="scroll-list">
             @if (_loading) { <div class="loader">Cargando...</div> }
             else {
                 @if (_subModule == "fields") {
                     @foreach(var field in _fields) {
                         <div class="list-item @(_selectedId == field.Id ? "active" : "")" @onclick="() => SelectItem(field.Id)">
                             @field.Name
                         </div>
                     }
                 }
                 else if (_subModule == "activities") {
                     @foreach(var activity in _activities) {
                         <div class="list-item @(_selectedId == activity.Id ? "active" : "")" @onclick="() => SelectItem(activity.Id)">
                             @activity.Name
                         </div>
                     }
                 }
             }
        </div>
    </div>
    <div class="detail-panel">
        @if (_selectedId != null || _isNew) {
            <div class="detail-form">
                <h3>Editar @_subModuleDisplay</h3>
                <div class="form-body">
                    <div class="form-group">
                        <label>Nombre</label>
                        <input type="text" @bind="_editName" />
                    </div>
                    @if (_subModule == "fields") {
                        <div class="form-group">
                            <label>Descripción</label>
                            <textarea @bind="_editDesc"></textarea>
                        </div>
                    }
                </div>
                <div class="form-actions">
                    <button class="btn-secondary" @onclick="() => _selectedId = null">Cancelar</button>
                    <button class="btn-primary" @onclick="Save">Guardar Cambios</button>
                </div>
            </div>
        } else {
            <div class="empty-detail">
                <img src="icon-192.png" style="opacity: 0.2; width: 100px;" />
                <p>Seleccione un elemento para editar o cree uno nuevo.</p>
            </div>
        }
    </div>
</div>

@code {
    private string _subModule = "fields";
    private string _subModuleDisplay => _subModule switch { "fields" => "Campos", "activities" => "Actividades", "categories" => "Categorías", "users" => "Usuarios", _ => "" };
    private string? _selectedId;
    private bool _isNew = false;
    private bool _loading = false;

    private List<FieldMessage> _fields = new();
    private List<ActivityMessage> _activities = new();

    private string _editName = "";
    private string _editDesc = "";

    protected override async Task OnInitializedAsync() {
        State.OnChange += async () => { await LoadData(); StateHasChanged(); };
        await LoadData();
    }

    private async Task SetSubModule(string mod) {
        _subModule = mod;
        _selectedId = null;
        _isNew = false;
        await LoadData();
    }

    private async Task LoadData() {
        if (string.IsNullOrEmpty(State.SelectedTenantId)) return;
        _loading = true;
        try {
            var req = new GetCatalogRequest { TenantId = State.SelectedTenantId };
            if (_subModule == "fields") _fields = (await Client.GetFieldsAsync(req)).Fields.ToList();
            else if (_subModule == "activities") _activities = (await Client.GetActivitiesAsync(req)).Activities.ToList();
        } finally { _loading = false; }
    }

    private void SelectItem(string id) {
        _selectedId = id;
        _isNew = false;
        if (_subModule == "fields") {
            var f = _fields.First(x => x.Id == id);
            _editName = f.Name;
            _editDesc = f.Description;
        }
    }

    private void AddNew() {
        _isNew = true;
        _selectedId = null;
        _editName = "";
        _editDesc = "";
    }

    private async Task Save() {
        // Implement save logic calling CRUD endpoints
    }

    public void Dispose() { State.OnChange -= async () => {}; }
}
