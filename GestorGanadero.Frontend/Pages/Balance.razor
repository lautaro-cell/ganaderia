@page "/balance"
@using GestorGanadero.Frontend.Services
@using GestorGanadero.Grpc.V1
@inject LivestockService.LivestockServiceClient Client
@inject AppState State
@implements IDisposable

<div class="module-header">
    <h1>Balance de Existencias</h1>
    <div class="filters">
        <div class="filter-group">
            <label>Fecha</label>
            <input type="date" @bind="State.FilterDate" @bind:event="oninput" />
        </div>
        <div class="filter-group">
            <label>Vista</label>
            <select @bind="_categoryView">
                <option value="gestor">Vista Gestor</option>
                <option value="cliente">Vista Cliente</option>
            </select>
        </div>
        <button class="btn-primary" @onclick="LoadBalance">Actualizar</button>
    </div>
</div>

<div class="balance-content">
    @if (_loading)
    {
        <div class="loading">Cargando reporte...</div>
    }
    else if (_report?.Items.Any() == true)
    {
        <table class="tree-table">
            <thead>
                <tr>
                    <th>Concepto (Campo / Categoría)</th>
                    <th class="text-end">Cabezas</th>
                    <th class="text-end">Total KG</th>
                    <th class="text-end">KG/CAB</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var group in _report.Items.GroupBy(i => i.FieldName))
                {
                    <tr class="row-group">
                        <td colspan="4">
                            <span class="folder-icon">📁</span> @group.Key
                        </td>
                    </tr>
                    @foreach (var item in group)
                    {
                        <tr class="row-item">
                            <td class="ps-4">@item.CategoryName</td>
                            <td class="text-end">@item.HeadCount.ToString("N0")</td>
                            <td class="text-end">@item.TotalWeight.ToString("N2")</td>
                            <td class="text-end">@((item.HeadCount > 0 ? item.TotalWeight / item.HeadCount : 0).ToString("N2"))</td>
                        </tr>
                    }
                    <tr class="row-subtotal">
                         <td class="fw-bold ps-2">Subtotal @group.Key</td>
                         <td class="text-end fw-bold">@group.Sum(i => i.HeadCount).ToString("N0")</td>
                         <td class="text-end fw-bold">@group.Sum(i => i.TotalWeight).ToString("N2")</td>
                         <td class="text-end fw-bold">-</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="row-total">
                    <td>TOTAL GENERAL</td>
                    <td class="text-end">@_report.Items.Sum(i => i.HeadCount).ToString("N0")</td>
                    <td class="text-end">@_report.Items.Sum(i => i.TotalWeight).ToString("N2")</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    }
    else
    {
        <div class="empty-state">No hay datos para los filtros seleccionados.</div>
    }
</div>

@code {
    private BalanceReport? _report;
    private bool _loading = false;
    private string _categoryView = "gestor";

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;
        await LoadBalance();
    }

    private async Task LoadBalance()
    {
        if (string.IsNullOrEmpty(State.SelectedTenantId)) return;

        _loading = true;
        try
        {
            var request = new GetBalanceRequest
            {
                TenantId = State.SelectedTenantId,
                Date = Google.Protobuf.WellKnownTypes.Timestamp.FromDateTime(State.FilterDate.ToUniversalTime()),
                CategoryView = _categoryView
            };

            _report = await Client.GetBalanceAsync(request);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading balance: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }
}
