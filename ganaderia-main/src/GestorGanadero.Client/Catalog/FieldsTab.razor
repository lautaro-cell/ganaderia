@using GestorGanadero.Client.Catalog
@using System.Collections.Generic
@using System.Linq
@inject CatalogClientService Catalog

<div>
  <div style="display:flex; gap:8px; align-items:center; margin-bottom:8px;">
    <h3 style="margin:0;">Campos</h3>
    <button class="btn" style="background:#C0392B; color:#fff; border:none; padding:6px 12px; border-radius:6px;" @onclick="OpenNew">Nuevo Campo</button>
  </div>
  <div class="grid" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:12px;">
    @foreach (var f in Fields)
    {
      <div class="card" style="background:#111; border:1px solid #333; padding:12px; border-radius:8px;">
        <div style="font-weight:600;">@f.Name</div>
        <div style="color:#fff; font-size:12px;">@f.Description</div>
        <div style="margin-top:6px;"><span class="badge" style="background:@(f.IsActive?"#1e7e34":"#6c757d"); padding:4px 8px; border-radius:999px;">@(f.IsActive ? "Activo" : "Inactivo")</span></div>
        <div style="margin-top:6px; display:flex; gap:6px;">
          <button class="btn" style="background:#444; color:#fff; padding:6px 8px; border-radius:6px;" @onclick="() => EditField(f)">✎</button>
          <button class="btn" style="background:#C0392B; color:#fff; padding:6px 8px; border-radius:6px;" @onclick="() => DeleteField(f.Id)">🗑</button>
        </div>
      </div>
    }
  </div>
  <FieldFormDrawer IsOpen="IsFieldFormOpen" Field="SelectedField" OnClose="CloseFieldForm" OnSave="HandleFieldSave" />
</div>

@code {
  private List<GestorGanadero.Services.Catalog.Contracts.FieldMessage> Fields = new();
  private bool IsFieldFormOpen = false;
  private GestorGanadero.Services.Catalog.Contracts.FieldMessage? SelectedField;

  protected override async Task OnInitializedAsync()
  {
    var r = await Catalog.GetFieldsAsync(new GestorGanadero.Services.Catalog.Contracts.GetCatalogRequest { TenantId = "TenantA" });
    if (r.Success && r.Data != null) Fields = r.Data.Fields.ToList();
  }

  private void OpenNew() { SelectedField = new GestorGanadero.Services.Catalog.Contracts.FieldMessage(); IsFieldFormOpen = true; }
  private void CloseFieldForm() { IsFieldFormOpen = false; }
  private void EditField(GestorGanadero.Services.Catalog.Contracts.FieldMessage f) { SelectedField = f; IsFieldFormOpen = true; }
  private void DeleteField(string id) { Fields.RemoveAll(x => x.Id == id); }
  private Task HandleFieldSave(GestorGanadero.Services.Catalog.Contracts.FieldMessage f) { IsFieldFormOpen = false; return Task.CompletedTask; }
}
