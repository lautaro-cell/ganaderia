@using GestorGanadero.Services.Common.Contracts
@using GestorGanadero.Services.Identity.Contracts
@using GestorGanadero.Services.Catalog.Contracts
@using GestorGanadero.Client.Services
@using Google.Protobuf.WellKnownTypes
@inject AppStateContainer State
@inject IdentityService.IdentityServiceClient GrpcClient
@inject CatalogService.CatalogServiceClient CatalogClient
@inject IJSRuntime JS

<div class="flex flex-col gap-6">
    <!-- Breadcrumbs -->
    <div class="flex items-center gap-2 text-[11px] font-medium text-text-secondary uppercase tracking-widest opacity-60">
        <a href="/" class="hover:text-white transition-colors no-underline">Inicio</a>
        <span class="material-symbols-outlined text-[14px]">chevron_right</span>
        <span class="cursor-default">Administración</span>
        <span class="material-symbols-outlined text-[14px]">chevron_right</span>
        <span class="text-primary font-bold">Usuarios</span>
    </div>

    <div class="flex flex-wrap justify-between items-end gap-4">
        <div class="flex flex-col gap-1 max-w-2xl">
            <h2 class="text-white text-2xl font-bold tracking-tight">Gestión de Usuarios</h2>
            <p class="text-text-secondary text-sm">Administre los roles de acceso y los permisos de los usuarios del sistema. Asegure que los usuarios de tipo <span class="text-primary font-bold">CLIENTE</span> estén correctamente vinculados a un Tenant ID único para fines de auditoría.</p>
        </div>
        <button class="flex min-w-[140px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 px-5 bg-primary hover:bg-red-700 transition-colors text-white text-sm font-bold leading-normal tracking-tight shadow-lg shadow-primary/20" @onclick="OpenInvite">
            <span class="material-symbols-outlined mr-2">person_add</span>
            <span>Nuevo Usuario</span>
        </button>
    </div>

    <!-- Search and Filters -->
    <div class="flex flex-wrap items-center justify-between gap-4 bg-surface-darker/50 p-4 rounded-xl border border-border-dark/50 shadow-sm">
        <div class="flex-1 min-w-[300px] relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-text-secondary">search</span>
            <input type="text" class="w-full bg-surface-dark border border-border-dark rounded-lg py-2 pl-10 pr-4 text-sm text-white focus:outline-none focus:border-primary transition-colors" 
                   placeholder="Buscar por nombre, email o Tenant ID..." @bind="_searchTerm" @bind:event="oninput" />
        </div>
        <div class="flex items-center gap-2">
            @foreach (var role in new[] { "Todos", "Admin", "Auditor", "Cliente" })
            {
                <button class="px-4 py-1.5 rounded-full text-xs font-bold transition-all border @(_roleFilter == role ? "bg-primary text-white border-primary shadow-md shadow-primary/20" : "bg-surface-dark border-border-dark text-text-secondary hover:bg-surface-darker hover:border-text-secondary")"
                        @onclick="() => _roleFilter = role">
                    @if (role != "Todos")
                    {
                        <span class="w-2 h-2 rounded-full inline-block mr-1.5 @GetRoleDotClass(role)"></span>
                    }
                    @role
                </button>
            }
        </div>
    </div>

    @if (_users == null)
    {
        <div class="flex flex-col items-center justify-center py-24 gap-4">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-primary"></div>
            <p class="text-text-secondary animate-pulse text-sm font-medium">Cargando base de usuarios...</p>
        </div>
    }
    else if (!FilteredUsers.Any())
    {
        <div class="flex flex-col items-center justify-center py-24 bg-surface-darker/30 rounded-2xl border border-dashed border-border-dark">
            <span class="material-symbols-outlined text-6xl text-text-disabled mb-4 opacity-20">group_off</span>
            <h3 class="text-text-secondary font-bold text-lg">No se encontraron resultados</h3>
            <p class="text-text-disabled text-sm">Intente con otro término de búsqueda o filtro.</p>
        </div>
    }
    else
    {
        <div class="overflow-hidden rounded-xl border border-border-dark bg-surface-dark shadow-xl">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-surface-darker/50 border-b border-border-dark">
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-text-secondary">Usuario</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-text-secondary text-center">Rol</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-text-secondary text-center">Tenant ID</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-text-secondary text-center">Estado</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-text-secondary text-center">Último Acceso</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-text-secondary text-right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-dark/30">
                        @foreach (var u in FilteredUsers)
                        {
                            <tr class="hover:bg-white/5 transition-colors group">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-full bg-surface-darker border border-border-dark flex items-center justify-center text-white font-black text-sm shadow-inner group-hover:border-primary/40 transition-colors">
                                            @GetInitials(u.Name)
                                        </div>
                                        <div class="flex flex-col">
                                            <span class="text-white font-bold text-sm">@(string.IsNullOrWhiteSpace(u.Name) ? "-" : u.Name)</span>
                                            <span class="text-text-secondary text-xs">@u.Email</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-black border uppercase tracking-wider @GetRoleBadgeClass(u.RoleName)">
                                        <span class="w-1.5 h-1.5 rounded-full @GetRoleDotClass(u.RoleName)"></span>
                                        @u.RoleName
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    @if (string.IsNullOrEmpty(u.TenantId))
                                    {
                                        <span class="text-text-disabled text-xs italic opacity-50">- Global -</span>
                                    }
                                    else
                                    {
                                        <span class="font-mono text-xs text-text-secondary bg-surface-darker px-2 py-0.5 rounded border border-border-dark/50">#TEN-@u.TenantId.PadLeft(4, '0')</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-center">
                                    @if (u.IsActive)
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-green-500/10 text-green-400 border border-green-500/20">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-yellow-500/10 text-yellow-400 border border-yellow-500/20">Invitado</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-center">
                                    @if (!string.IsNullOrEmpty(u.LastLoginAt))
                                    {
                                        <span class="text-text-secondary text-xs font-mono">@FormatDate(u.LastLoginAt)</span>
                                    }
                                    else
                                    {
                                        <span class="text-text-disabled text-xs italic">Nunca</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-1 opacity-40 group-hover:opacity-100 transition-opacity">
                                        <button class="p-2 hover:bg-surface-darker rounded-lg text-text-secondary hover:text-white transition-colors" title="Editar" @onclick="() => Edit(u)">
                                            <span class="material-symbols-outlined text-lg">edit</span>
                                        </button>
                                        <button class="p-2 hover:bg-red-500/10 rounded-lg text-text-secondary hover:text-red-400 transition-colors" title="Eliminar" @onclick="() => Delete(u)">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (_showModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm" @onclick="() => _showModal = false">
        <div class="w-full max-w-md bg-surface-dark border border-border-dark rounded-2xl shadow-2xl overflow-hidden" @onclick:stopPropagation>
            <div class="flex items-center justify-between px-6 py-4 border-b border-border-dark bg-surface-darker/50">
                <h3 class="text-lg font-bold text-white">@(_editing ? "Editar Usuario" : "Invitar Usuario")</h3>
                <button class="text-text-secondary hover:text-white transition-colors" @onclick="() => _showModal = false">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            
            <div class="p-6 flex flex-col gap-5">
                <div class="flex flex-col gap-2">
                    <label class="text-xs font-bold text-text-secondary uppercase tracking-wider">Email</label>
                    <input type="email" @bind="_model.Email" class="w-full bg-surface-darker border border-border-dark rounded-lg px-4 py-2.5 text-sm text-white focus:outline-none focus:border-primary disabled:opacity-50" disabled="@_editing" placeholder="usuario@ejemplo.com" />
                </div>
                
                <div class="flex flex-col gap-2">
                    <label class="text-xs font-bold text-text-secondary uppercase tracking-wider">Nombre Completo</label>
                    <input type="text" @bind="_model.Name" class="w-full bg-surface-darker border border-border-dark rounded-lg px-4 py-2.5 text-sm text-white focus:outline-none focus:border-primary" placeholder="Ej: Juan Pérez" />
                </div>
                
                <div class="flex flex-col gap-2">
                    <label class="text-xs font-bold text-text-secondary uppercase tracking-wider">Rol de Acceso</label>
                    <div class="grid grid-cols-3 gap-2">
                        @foreach (var r in new[] { ("Admin", "Admin"), ("Auditor", "Auditor"), ("Cliente", "Cliente") })
                        {
                            <button class="px-2 py-2 rounded-lg text-[11px] font-bold border transition-all @(_model.RoleName == r.Item1 ? "bg-primary/10 border-primary text-primary" : "bg-surface-darker border-border-dark text-text-secondary hover:border-text-secondary")"
                                    @onclick="() => _model.RoleName = r.Item1">
                                @r.Item2
                            </button>
                        }
                    </div>
                </div>

                @if (_editing)
                {
                    <div class="flex items-center gap-3 p-3 bg-surface-darker rounded-lg border border-border-dark">
                        <input type="checkbox" @bind="_model.IsActive" id="usrAct" class="w-4 h-4 rounded border-border-dark bg-surface-dark text-primary focus:ring-primary focus:ring-offset-0" />
                        <label for="usrAct" class="text-sm font-medium text-white cursor-pointer select-none">Usuario Activo</label>
                    </div>

                    <!-- Campos asignados (Tarea 7.4/7.5) -->
                    <div class="flex flex-col gap-2">
                        <label class="text-xs font-bold text-text-secondary uppercase tracking-wider">Campos Asignados</label>
                        @if (_fields != null && _fields.Any())
                        {
                            <div class="flex flex-wrap gap-2 p-3 bg-surface-darker rounded-lg border border-border-dark">
                                @foreach (var f in _fields)
                                {
                                    var isSel = _selectedFieldIds.Contains(f.Id);
                                    <button type="button"
                                            class="px-3 py-1.5 rounded-lg text-xs font-bold border transition-all @(isSel ? "bg-primary/10 border-primary/40 text-primary" : "bg-surface-dark border-border-dark text-text-secondary hover:border-text-secondary")"
                                            @onclick="() => ToggleField(f.Id)">
                                        @if (isSel) { <span class="material-symbols-outlined text-[13px] mr-0.5">check</span> }
                                        @f.Name
                                    </button>
                                }
                            </div>
                            <p class="text-text-disabled text-[11px]">Los Auditores y Operadores solo ven datos de los campos asignados.</p>
                        }
                        else
                        {
                            <p class="text-text-disabled text-xs">No hay campos disponibles.</p>
                        }
                    </div>

                    @if (IsReadOnlyRole(_model.RoleName))
                    {
                        <div class="flex items-center gap-2 p-3 bg-amber-500/10 border border-amber-500/30 rounded-lg text-amber-400 text-xs">
                            <span class="material-symbols-outlined text-[16px]">shield</span>
                            El rol <strong>@_model.RoleName</strong> tiene acceso de solo lectura — no puede crear ni modificar datos.
                        </div>
                    }
                }
            </div>

            <div class="px-6 py-4 bg-surface-darker/50 border-t border-border-dark flex justify-end gap-3">
                <button class="px-5 py-2 rounded-lg text-sm font-bold text-text-secondary hover:text-white transition-colors" @onclick="() => _showModal = false">
                    Cancelar
                </button>
                <button class="flex items-center justify-center min-w-[120px] px-5 py-2 rounded-lg text-sm font-bold text-white bg-primary hover:bg-red-700 transition-colors shadow-lg shadow-primary/20" @onclick="Submit" disabled="@_saving">
                    @if (_saving)
                    {
                        <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-white mr-2"></div>
                    }
                    @(_editing ? "Guardar" : "Enviar Invitación")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<UserMessage>? _users;
    private List<FieldMessage>? _fields;
    private HashSet<string> _selectedFieldIds = new();
    private string _searchTerm = "";
    private string _roleFilter = "Todos";
    private bool _showModal;
    private bool _editing;
    private bool _saving;
    private UserMessage _model = new() { RoleName = "Cliente" };

    private IEnumerable<UserMessage> FilteredUsers => _users?
        .Where(u => string.IsNullOrEmpty(_searchTerm) || 
                   (u.Name?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) || 
                   (u.Email?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                   (u.TenantId?.Contains(_searchTerm) ?? false))
        .Where(u => _roleFilter == "Todos" || u.RoleName.Equals(_roleFilter, StringComparison.OrdinalIgnoreCase)) ?? Enumerable.Empty<UserMessage>();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        try
        {
            var r = await GrpcClient.GetUsersAsync(new Empty());
            _users = r.Users.ToList();
            var fr = await CatalogClient.GetFieldsAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId });
            _fields = fr.Fields.ToList();
        }
        catch (Exception ex) { Console.WriteLine($"Error cargando usuarios: {ex.Message}"); }
    }

    private void ToggleField(string id) { if (!_selectedFieldIds.Remove(id)) _selectedFieldIds.Add(id); }

    private static bool IsReadOnlyRole(string? role) =>
        string.Equals(role, "Auditor", StringComparison.OrdinalIgnoreCase);

    private static string FormatDate(string? iso)
    {
        if (string.IsNullOrEmpty(iso)) return "-";
        if (DateTimeOffset.TryParse(iso, out var dt))
            return dt.LocalDateTime.ToString("dd/MM/yyyy HH:mm");
        return iso[..Math.Min(10, iso.Length)];
    }

    private void OpenInvite()
    {
        _editing = false;
        _selectedFieldIds = new HashSet<string>();
        _model = new UserMessage { RoleName = "Cliente", IsActive = true, TenantId = State.ActiveTenantId };
        _showModal = true;
    }

    private void Edit(UserMessage u)
    {
        _editing = true;
        _model = new UserMessage { Id = u.Id, Name = u.Name, Email = u.Email, RoleName = u.RoleName, IsActive = u.IsActive, TenantId = u.TenantId };
        _selectedFieldIds = new HashSet<string>(u.AssignedFieldIds);
        _showModal = true;
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_model.Email) || string.IsNullOrWhiteSpace(_model.Name)) return;
        _saving = true; StateHasChanged();
        try
        {
            if (_editing)
            {
                _model.AssignedFieldIds.Clear();
                _model.AssignedFieldIds.AddRange(_selectedFieldIds);
                var r = await GrpcClient.UpdateUserAsync(_model);
                if (r.Success) await Load();
            }
            else
            {
                var r = await GrpcClient.InviteUserAsync(new InviteUserRequest { Email = _model.Email, Name = _model.Name, RoleName = _model.RoleName, TenantId = State.ActiveTenantId });
                if (r.Success) await Load();
            }
            _showModal = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving user: {ex.Message}");
        }
        finally { _saving = false; StateHasChanged(); }
    }

    private async Task Delete(UserMessage u)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Está seguro que desea eliminar el acceso de {u.Name}?")) return;
        try 
        { 
            await GrpcClient.DeleteUserAsync(new DeleteEntityRequest { Id = u.Id, TenantId = State.ActiveTenantId }); 
            await Load(); 
        } 
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting user: {ex.Message}");
        }
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name) || name == "-") return "??";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpper();
        return (parts[0][0].ToString() + parts[1][0].ToString()).ToUpper();
    }

    private string GetRoleDotClass(string? role) => (role?.ToLower()) switch
    {
        "admin" => "bg-blue-400",
        "auditor" => "bg-purple-400",
        "cliente" => "bg-green-400",
        _ => "bg-text-disabled"
    };

    private string GetRoleBadgeClass(string? role) => (role?.ToLower()) switch
    {
        "admin" => "bg-blue-900/20 border-blue-500/30 text-blue-400",
        "auditor" => "bg-purple-900/20 border-purple-500/30 text-purple-400",
        "cliente" => "bg-green-900/20 border-green-500/30 text-green-400",
        _ => "bg-surface-darker border-border-dark text-text-disabled"
    };
}
