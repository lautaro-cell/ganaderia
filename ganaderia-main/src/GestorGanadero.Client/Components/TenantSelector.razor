@using GestorGanadero.Client.Services
@using GestorGanadero.Services.Identity.Contracts
@using Google.Protobuf.WellKnownTypes
@inject IdentityService.IdentityServiceClient Client
@inject AppStateContainer State
@implements IDisposable

<div class="tenant-selector">
    <select @onchange="OnTenantChanged" value="@State.ActiveTenantId">
        <option value="">Seleccionar Empresa...</option>
        @foreach (var tenant in _tenants)
        {
            <option value="@tenant.Id">@tenant.Name</option>
        }
    </select>
</div>

@code {
    private List<TenantMessage> _tenants = new();

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;
        try
        {
            var response = await Client.GetAvailableTenantsAsync(new Empty());
            _tenants = response.Tenants.ToList();
            
            if (string.IsNullOrEmpty(State.ActiveTenantId) && _tenants.Any())
            {
                State.ActiveTenantId = _tenants.First().Id;
                State.ActiveTenantName = _tenants.First().Name;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading tenants: {ex.Message}");
        }
    }

    private void OnTenantChanged(ChangeEventArgs e)
    {
        var tenantId = e.Value?.ToString();
        State.ActiveTenantId = tenantId ?? string.Empty;
        var tenant = _tenants.FirstOrDefault(t => t.Id == tenantId);
        if (tenant != null)
            State.ActiveTenantName = tenant.Name;
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }
}
