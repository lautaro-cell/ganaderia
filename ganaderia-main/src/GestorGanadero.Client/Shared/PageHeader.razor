@* Page header component - standardized style *@
<div class="page-header">
  <div class="page-header-row">
    <div>
      <h1>@Title</h1>
      @if (Breadcrumb != null)
      {
        <div class="subtitle">@Breadcrumb</div>
      }
    </div>
    @if (Actions != null)
    {
      <div class="actions">
        @Actions
      </div>
    }
  </div>
  @if (ChildContent != null)
  {
    <div class="header-content mt-md">
      @ChildContent
    </div>
  }
</div>

@code {
  [Parameter] public string Title { get; set; } = "Página";
  [Parameter] public RenderFragment? Breadcrumb { get; set; }
  [Parameter] public RenderFragment? Actions { get; set; }
  [Parameter] public RenderFragment? ChildContent { get; set; }
}
