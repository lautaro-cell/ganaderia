# --- CONFIGURACIÓN DE BASE DE DATOS ---
# Para Docker usar: Host=db
ConnectionStrings__DefaultConnection="Host=localhost;Port=5432;Database=gestor_ganadero;Username=postgres;Password=password"

# --- CONFIGURACIÓN DE SEGURIDAD (JWT) ---
# Debe ser una cadena de al menos 32 caracteres
Jwt__Key="PONER_AQUÍ_UNA_CLAVE_SUPER_SECRETA_Y_LARGA"
Jwt__Issuer="gestor-ganadero"
Jwt__Audience="gestor-ganadero-client"

# --- CONFIGURACIÓN DE CORREO (SMTP) ---
Smtp__Host="smtp.gmail.com"
Smtp__Port=587
Smtp__Username=""
Smtp__Password=""
Smtp__UseSsl=false

# --- INFRAESTRUCTURA (DOCKER) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=gestor_ganadero
POSTGRES_PORT=5432

# --- OTROS ---
Database__RunSeedOnStartup=true
ASPNETCORE_ENVIRONMENT=Production
