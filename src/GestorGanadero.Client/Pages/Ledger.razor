@page "/ledger"
@using GestorGanadero.Client.Services
@using GestorGanadero.Grpc.V1
@using Google.Protobuf.WellKnownTypes
@inject LivestockService.LivestockServiceClient Client
@inject AppState State
@implements IDisposable

<div class="module-header">
    <h1>Libro Mayor y Sincronización</h1>
    <div class="tabs-subnav">
        <button class="@(_activeTab == "ledger" ? "active" : "")" @onclick="@(() => _activeTab = "ledger")">Auditoría Mayor</button>
        <button class="@(_activeTab == "sync" ? "active" : "")" @onclick="@(() => _activeTab = "sync")">Pendientes de Sincronización</button>
    </div>
</div>

<div class="ledger-container">
    @if (_activeTab == "ledger")
    {
        <div class="ledger-view">
             <div class="grid-actions">
                <input type="text" placeholder="Buscar por cuenta o descripción..." @bind="_searchTerm" class="search-input" />
                <button class="btn-primary" @onclick="LoadLedger">Consultar</button>
             </div>

             <table class="data-table">
                 <thead>
                     <tr>
                         <th>Fecha</th>
                         <th>Descripción</th>
                         <th>Cuenta</th>
                         <th class="text-end">Importe</th>
                         <th>Estado</th>
                     </tr>
                 </thead>
                 <tbody>
                     @if (_ledgerEntries.Any())
                     {
                        @foreach (var entry in _ledgerEntries)
                        {
                            <tr>
                                <td>@entry.Date.ToDateTime().ToLocalTime().ToString("dd/MM/yyyy")</td>
                                <td>@entry.Description</td>
                                <td><code class="account-code">@entry.AccountCode</code></td>
                                <td class="text-end fw-bold">$ @entry.Amount.ToString("N2")</td>
                                <td><span class="status-tag @entry.Status.ToLower()">@entry.Status</span></td>
                            </tr>
                        }
                     }
                     else
                     {
                         <tr><td colspan="5" class="empty">No hay registros para mostrar.</td></tr>
                     }
                 </tbody>
             </table>
        </div>
    }
    else
    {
        <div class="sync-view">
            <div class="sync-banner">
                <p>Cuentas pendientes de envío al ERP (GestorMax)</p>
                <button class="btn-primary" disabled="@(!_selectedIds.Any())" @onclick="SyncSelected">
                    Sincronizar @_selectedIds.Count Seleccionados
                </button>
            </div>

            <table class="data-table">
                 <thead>
                     <tr>
                         <th><input type="checkbox" @onchange="ToggleAll" /></th>
                         <th>Fecha</th>
                         <th>Descripción</th>
                         <th class="text-end">Importe</th>
                     </tr>
                 </thead>
                 <tbody>
                     @foreach (var entry in _pendingEntries)
                     {
                         <tr>
                             <td><input type="checkbox" checked="@_selectedIds.Contains(entry.Id)" @onchange="() => ToggleSelection(entry.Id)" /></td>
                             <td>@entry.Date.ToDateTime().ToString("dd/MM/yyyy")</td>
                             <td>@entry.Description</td>
                             <td class="text-end">$ @entry.Amount.ToString("N2")</td>
                         </tr>
                     }
                 </tbody>
            </table>
        </div>
    }
</div>

@code {
    private string _activeTab = "ledger";
    private string _searchTerm = "";
    private List<LedgerEntry> _ledgerEntries = new();
    private List<LedgerEntry> _pendingEntries = new();
    private HashSet<string> _selectedIds = new();

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += async () => {
            await LoadLedger();
            await LoadPending();
            StateHasChanged();
        };
        await LoadLedger();
        await LoadPending();
    }

    private async Task LoadLedger()
    {
        if (string.IsNullOrEmpty(State.SelectedTenantId)) return;
        _ledgerEntries.Clear();
        var filter = new LedgerFilter {
            TenantId = State.SelectedTenantId,
            SearchTerm = _searchTerm,
            PageIndex = 0,
            PageSize = 50
        };

        using var call = Client.GetLedger(filter);
        while (await call.ResponseStream.MoveNext(default))
        {
            _ledgerEntries.Add(call.ResponseStream.Current);
            StateHasChanged();
        }
    }

    private async Task LoadPending()
    {
        if (string.IsNullOrEmpty(State.SelectedTenantId)) return;
        try {
            var res = await Client.GetPendingSyncEventsAsync(new PendingSyncFilter { TenantId = State.SelectedTenantId });
            _pendingEntries = res.Entries.ToList();
        } catch { }
    }

    private void ToggleSelection(string id) {
        if (!_selectedIds.Remove(id)) _selectedIds.Add(id);
    }

    private void ToggleAll(ChangeEventArgs e) {
        if ((bool)e.Value!) _selectedIds = _pendingEntries.Select(x => x.Id).ToHashSet();
        else _selectedIds.Clear();
    }

    private async Task SyncSelected() {
        var req = new SyncRequest { EntryIds = { _selectedIds } };
        var res = await Client.SyncToERPAsync(req);
        _selectedIds.Clear();
        await LoadPending();
    }

    public void Dispose() {
        State.OnChange -= async () => {};
    }
}
