@page "/login"
@using GestorGanadero.Client.Services
@using System.ComponentModel.DataAnnotations
@inject IAuthService AuthService
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-brand">
            <div class="brand-icon">GG</div>
            <h1>Gestor Ganadero</h1>
            <p>Inicia sesión para continuar</p>
        </div>

        <EditForm Model="@model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />
            
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mb-md" style="margin-bottom:16px;">
                    <span class="material-icons" style="font-size:18px;">error</span>
                    @errorMessage
                </div>
            }

            <div class="form-group">
                <label for="email">Email</label>
                <InputText id="email" @bind-Value="model.Email" class="form-control" placeholder="admin@ganaderia.com" />
                <ValidationMessage For="@(() => model.Email)" />
            </div>

            <div class="form-group">
                <label for="password">Contraseña</label>
                <InputText id="password" @bind-Value="model.Password" type="password" class="form-control" placeholder="••••••••" />
                <ValidationMessage For="@(() => model.Password)" />
            </div>

            <button type="submit" class="btn btn-primary login-btn mt-md" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner"></span>
                    <span>Iniciando sesión...</span>
                }
                else
                {
                    <span class="material-icons" style="font-size:18px;">login</span>
                    <span>Iniciar Sesión</span>
                }
            </button>
        </EditForm>

        <div style="text-align:center; margin-top:24px; font-size:0.75rem; color:var(--text-muted);">
            Credenciales de prueba: admin@ganaderia.com / admin123
        </div>
    </div>
</div>

@code {
    private LoginModel model = new();
    private bool isLoading = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
        if (!string.IsNullOrEmpty(token))
            Nav.NavigateTo("/");
    }

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var success = await AuthService.LoginAsync(model.Email, model.Password);
            if (success)
                Nav.NavigateTo("/");
            else
                errorMessage = "Credenciales inválidas. Verifica tu email y contraseña.";
        }
        catch
        {
            errorMessage = "No se pudo conectar al servidor. Intenta de nuevo.";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    public class LoginModel
    {
        [Required(ErrorMessage = "El email es obligatorio.")]
        [EmailAddress(ErrorMessage = "Formato de email inválido.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "La contraseña es obligatoria.")]
        [MinLength(3, ErrorMessage = "La contraseña debe tener al menos 3 caracteres.")]
        public string Password { get; set; } = "";
    }
}
