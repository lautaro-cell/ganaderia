@page "/superadmin"
@layout GestorGanadero.Client.Layout.MainLayout
@using GestorGanadero.Services.Common.Contracts
@using GestorGanadero.Services.Identity.Contracts
@using GestorGanadero.Client.Services
@using Google.Protobuf.WellKnownTypes
@implements IDisposable
@inject AppStateContainer State
@inject IdentityService.IdentityServiceClient GrpcClient
@inject IJSRuntime JS

<div class="flex flex-col gap-6">
    <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-amber-400 text-2xl">shield</span>
        <div>
            <h2 class="text-white text-xl font-bold">SuperAdmin Dashboard</h2>
            <p class="text-text-secondary text-sm">Gestión global de empresas y sus configuraciones ERP.</p>
        </div>
    </div>

    @if (!State.IsSuperAdmin && !_localIsSuperAdmin)
    {
        <div class="flex items-center gap-3 p-6 rounded-2xl bg-red-500/10 border border-red-500/20 text-red-400">
            <span class="material-symbols-outlined text-2xl">gpp_bad</span>
            <p class="text-sm">No tienes permisos de SuperAdmin.</p>
        </div>
    }
    else
    {
        <!-- Crear Empresa -->
        <div class="bg-background-main border border-border-dark rounded-2xl p-6 shadow-xl shadow-black/20">
            <h3 class="text-white text-lg font-bold mb-4 flex items-center gap-2">
                <span class="material-symbols-outlined text-green-400">add_business</span>
                Crear Nueva Empresa
            </h3>
            <div class="flex items-end gap-4">
                <div class="flex-1">
                    <input @bind="_newTenantName" @bind:event="oninput"
                           class="w-full bg-surface-dark border border-border-dark rounded-xl px-4 py-2.5 text-white text-sm outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
                           placeholder="Ej: Ganadería Los Pinos" />
                </div>
                <button @onclick="CreateTenant" disabled="@_creating"
                        class="flex items-center gap-2 px-6 py-2.5 bg-green-600 hover:bg-green-700 disabled:bg-green-800 disabled:cursor-not-allowed text-white text-sm font-bold rounded-xl transition-colors">
                    <span class="material-symbols-outlined text-lg">add</span>
                    Crear Empresa
                </button>
            </div>
            @if (!string.IsNullOrEmpty(_createError))
            {
                <p class="text-red-400 text-sm mt-2">@_createError</p>
            }
        </div>

        <!-- Lista de Empresas -->
        <div class="bg-background-main border border-border-dark rounded-2xl overflow-hidden shadow-xl shadow-black/20">
            <div class="flex items-center justify-between px-6 py-4 border-b border-border-dark">
                <h3 class="text-white text-lg font-bold flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">business</span>
                    Empresas (@(_tenants?.Count ?? 0))
                </h3>
                <button @onclick="LoadTenants" class="flex items-center gap-1 px-3 py-1.5 rounded-lg bg-surface-darker border border-border-dark text-text-secondary hover:text-white transition-colors text-xs font-bold">
                    <span class="material-symbols-outlined text-sm">refresh</span>
                </button>
            </div>
            <table class="w-full text-left text-sm">
                <thead class="bg-surface-darker text-text-secondary uppercase text-[10px] tracking-widest border-b border-border-dark">
                    <tr>
                        <th class="px-6 py-4">Empresa</th>
                        <th class="px-6 py-4 text-center">DB ID</th>
                        <th class="px-6 py-4 text-center">Estado ERP</th>
                        <th class="px-6 py-4 text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border-dark/30">
                    @if (_tenants == null)
                    {
                        <tr><td colspan="4" class="px-6 py-12 text-center"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary mx-auto"></div></td></tr>
                    }
                    else if (!_tenants.Any())
                    {
                        <tr><td colspan="4" class="px-6 py-12 text-center text-text-disabled">No hay empresas.</td></tr>
                    }
                    else
                    {
                        @foreach (var t in _tenants)
                        {
                            <tr class="hover:bg-white/5 transition-colors">
                                <td class="px-6 py-4"><span class="text-white font-bold text-sm">@t.Name</span></td>
                                <td class="px-6 py-4 text-center">
                                    <span class="font-mono text-xs text-text-secondary bg-surface-darker px-2 py-1 rounded border border-border-dark/50">
                                        @(string.IsNullOrEmpty(t.GestorMaxDatabaseId) ? "—" : t.GestorMaxDatabaseId)
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    @{
                                        var (badgeColor, badgeIcon) = GetStatusBadge(t);
                                    }
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[10px] font-bold border @badgeColor">
                                        <span class="material-symbols-outlined text-[12px]">@badgeIcon</span>
                                        @(t.HasErpConfig ? t.StatusSummary : "Sin configurar")
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <button @onclick="() => OpenConfig(t)" class="flex items-center gap-1 px-3 py-1.5 rounded-lg bg-surface-darker border border-border-dark text-text-secondary hover:text-white hover:border-text-secondary transition-all text-xs font-bold">
                                            <span class="material-symbols-outlined text-sm">settings</span>
                                            Configurar
                                        </button>
                                        <button @onclick="() => ConfirmDelete(t)" disabled="@(_deletingId == t.Id)" class="flex items-center gap-1 px-3 py-1.5 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 hover:bg-red-500/20 transition-colors text-xs font-bold">
                                            <span class="material-symbols-outlined text-sm">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- ERP Config Modal -->
        @if (_showConfig && _status != null)
        {
            <div class="fixed inset-0 z-50 flex items-start justify-center p-4 pt-12 bg-black/80 backdrop-blur-sm overflow-y-auto" @onclick="CloseConfig">
                <div class="w-full max-w-xl bg-surface-dark border border-border-dark rounded-2xl shadow-2xl overflow-hidden" @onclick:stopPropagation>
                    <div class="flex items-center justify-between px-6 py-4 border-b border-border-dark bg-surface-darker/50">
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-primary">business</span>
                            <div>
                                <h3 class="text-base font-bold text-white">@_status.TenantName</h3>
                                <p class="text-[11px] text-text-disabled">Configuración ERP</p>
                            </div>
                        </div>
                        <button class="text-text-secondary hover:text-white transition-colors" @onclick="CloseConfig">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>
                    <div class="px-6 pt-5 pb-4 border-b border-border-dark/50 bg-surface-darker/20">
                        <h4 class="text-[11px] font-bold text-text-secondary uppercase tracking-wider mb-3 flex items-center gap-2">
                            <span class="material-symbols-outlined text-[14px]">monitor_heart</span> Estado de integración
                        </h4>
                        <div class="grid grid-cols-3 gap-3">
                            <div class="bg-surface-darker rounded-xl p-3 border border-border-dark/50">
                                <p class="text-[10px] text-text-disabled uppercase tracking-wider mb-1">Configuración</p>
                                @if (_status.IsConfigured)
                                {
                                    <p class="text-[11px] font-bold text-green-400 flex items-center gap-1"><span class="material-symbols-outlined text-[13px]">check_circle</span>DB: @_status.GestorDatabaseId</p>
                                    <p class="text-[10px] text-text-disabled mt-0.5">API: ****@_status.ApiKeyLast4</p>
                                }
                                else
                                {
                                    <p class="text-[11px] font-bold text-yellow-400 flex items-center gap-1"><span class="material-symbols-outlined text-[13px]">warning</span>Sin configurar</p>
                                }
                            </div>
                            <div class="bg-surface-darker rounded-xl p-3 border border-border-dark/50">
                                <p class="text-[10px] text-text-disabled uppercase tracking-wider mb-1">Última verificación</p>
                                @if (!string.IsNullOrEmpty(_status.LastTestedAt))
                                {
                                    <p class="text-[11px] font-bold @(_status.LastTestOk == true ? "text-green-400" : "text-red-400") flex items-center gap-1"><span class="material-symbols-outlined text-[13px]">@(_status.LastTestOk == true ? "check_circle" : "cancel")</span>@(_status.LastTestOk == true ? "OK" : "Error")</p>
                                    <p class="text-[10px] text-text-disabled mt-0.5">@FormatDate(_status.LastTestedAt)</p>
                                }
                                else
                                { <p class="text-[11px] text-text-disabled">Sin datos</p> }
                            </div>
                            <div class="bg-surface-darker rounded-xl p-3 border border-border-dark/50">
                                <p class="text-[10px] text-text-disabled uppercase tracking-wider mb-1">Última sync</p>
                                @if (!string.IsNullOrEmpty(_status.LastSyncAt))
                                {
                                    <p class="text-[11px] font-bold @(_status.LastSyncOk == true ? "text-green-400" : "text-red-400") flex items-center gap-1"><span class="material-symbols-outlined text-[13px]">@(_status.LastSyncOk == true ? "sync" : "sync_problem")</span>@(_status.LastSyncOk == true ? "OK" : "Error")</p>
                                    <p class="text-[10px] text-text-disabled mt-0.5">@FormatDate(_status.LastSyncAt)</p>
                                }
                                else
                                { <p class="text-[11px] text-text-disabled">Sin datos</p> }
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(_status.LastTestError) && _status.LastTestOk == false)
                        {
                            <div class="mt-2 flex items-start gap-2 bg-red-900/20 border border-red-800/40 rounded-lg px-3 py-2"><span class="material-symbols-outlined text-red-400 text-[14px] mt-0.5">error</span><p class="text-[11px] text-red-300">@_status.LastTestError</p></div>
                        }
                        @if (!string.IsNullOrEmpty(_status.LastSyncError) && _status.LastSyncOk == false)
                        {
                            <div class="mt-2 flex items-start gap-2 bg-orange-900/20 border border-orange-800/40 rounded-lg px-3 py-2"><span class="material-symbols-outlined text-orange-400 text-[14px] mt-0.5">sync_problem</span><p class="text-[11px] text-orange-300">@_status.LastSyncError</p></div>
                        }
                        <div class="flex gap-2 mt-3">
                            <button @onclick="VerifyConnection" disabled="@(_verifying || !_status.IsConfigured)" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border text-xs font-bold transition-all disabled:opacity-50 @(_verifyResult?.Success == true ? "border-green-600 text-green-400 bg-green-900/20" : _verifyResult?.Success == false ? "border-red-600 text-red-400 bg-red-900/20" : "border-border-dark text-text-secondary hover:text-white hover:border-text-secondary bg-surface-darker")">
                                @if (_verifying) { <div class="animate-spin rounded-full h-3 w-3 border-b-2 border-current"></div> }
                                else { <span class="material-symbols-outlined text-[14px]">wifi_find</span> }
                                @(_verifying ? "Verificando..." : "Verificar conexión")
                                @if (_verifyResult != null) { <span class="opacity-70">(@_verifyResult.LatencyMs ms)</span> }
                            </button>
                            <button @onclick="TriggerSync" disabled="@(_syncing || !_status.IsConfigured)" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-border-dark text-xs font-bold text-text-secondary hover:text-white hover:border-text-secondary bg-surface-darker transition-all disabled:opacity-50">
                                @if (_syncing) { <div class="animate-spin rounded-full h-3 w-3 border-b-2 border-current"></div> }
                                else { <span class="material-symbols-outlined text-[14px]">sync</span> }
                                @(_syncing ? "Sincronizando..." : "Sincronizar ahora")
                            </button>
                        </div>
                    </div>
                    <div class="p-6 flex flex-col gap-4">
                        <h4 class="text-[11px] font-bold text-text-secondary uppercase tracking-wider flex items-center gap-2"><span class="material-symbols-outlined text-[14px]">edit</span>Configuración</h4>
                        @if (!string.IsNullOrEmpty(_msg))
                        {
                            <div class="p-3 rounded-lg @(_msgOk ? "bg-green-500/10 text-green-400 border border-green-500/20" : "bg-red-500/10 text-red-400 border border-red-500/20") text-xs flex items-start gap-2"><span class="material-symbols-outlined text-[14px] mt-0.5">@(_msgOk ? "check_circle" : "error")</span>@_msg</div>
                        }
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-text-secondary uppercase tracking-wider">Razón social</label>
                            <input type="text" @bind="_form.TenantName" class="w-full bg-surface-darker border border-border-dark rounded-lg px-4 py-2.5 text-sm text-white focus:outline-none focus:border-primary placeholder:text-text-disabled" />
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[11px] font-bold text-text-secondary uppercase tracking-wider">GestorMax DB ID</label>
                                <input type="number" min="1" @bind="_form.GestorDatabaseId" class="w-full bg-surface-darker border border-border-dark rounded-lg px-4 py-2.5 text-sm text-white font-mono focus:outline-none focus:border-primary" />
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[11px] font-bold text-text-secondary uppercase tracking-wider">URL base ERP</label>
                                <input type="url" @bind="_form.BaseUrl" class="w-full bg-surface-darker border border-border-dark rounded-lg px-4 py-2.5 text-sm text-white font-mono focus:outline-none focus:border-primary" />
                            </div>
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[11px] font-bold text-text-secondary uppercase tracking-wider">API Key</label>
                            <div class="relative">
                                <input type="@(_showKey ? "text" : "password")" @bind="_form.ApiKey" class="w-full bg-surface-darker border border-border-dark rounded-lg pl-4 pr-12 py-2.5 text-sm text-white font-mono focus:outline-none focus:border-primary" placeholder="Dejar vacío para mantener la actual" />
                                <button @onclick="() => _showKey = !_showKey" class="absolute right-2 top-1/2 -translate-y-1/2 text-text-secondary hover:text-white"><span class="material-symbols-outlined text-lg">@(_showKey ? "visibility_off" : "visibility")</span></button>
                            </div>
                        </div>
                    </div>
                    <div class="px-6 py-4 bg-surface-darker/50 border-t border-border-dark flex justify-end gap-3">
                        <button class="px-5 py-2 rounded-lg text-sm font-bold text-text-secondary hover:text-white transition-colors" @onclick="CloseConfig">Cancelar</button>
                        <button @onclick="SaveConfig" disabled="@_saving" class="flex items-center justify-center min-w-[140px] gap-2 px-5 py-2 rounded-lg text-sm font-bold text-white bg-primary hover:bg-red-700 transition-colors shadow-lg shadow-primary/20 disabled:opacity-50">
                            @if (_saving) { <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-white"></div> }
                            else { <span class="material-symbols-outlined text-[18px]">save</span> }
                            @(_saving ? "Guardando..." : "Guardar y sincronizar")
                        </button>
                    </div>
                </div>
            </div>
        }

        <!-- Delete Confirm -->
        @if (_showDeleteConfirm)
        {
            <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm" @onclick="() => _showDeleteConfirm = false">
                <div class="w-full max-w-md bg-surface-dark border border-border-dark rounded-2xl shadow-2xl p-6" @onclick:stopPropagation>
                    <div class="flex items-center gap-3 mb-4"><span class="material-symbols-outlined text-red-400 text-3xl">warning</span><div><h3 class="text-white text-base font-bold">Eliminar Empresa</h3><p class="text-text-secondary text-sm">Esta acción no se puede deshacer.</p></div></div>
                    <p class="text-text-secondary text-sm mb-6">¿Estás seguro de eliminar <strong class="text-white">@_tenantToDelete?.Name</strong>?</p>
                    <div class="flex gap-3 justify-end">
                        <button @onclick="() => _showDeleteConfirm = false" class="px-4 py-2 rounded-lg bg-surface-darker border border-border-dark text-text-secondary hover:text-white transition-colors text-sm font-bold">Cancelar</button>
                        <button @onclick="DeleteTenant" disabled="@(_deleting)" class="px-4 py-2 rounded-lg bg-red-600 hover:bg-red-700 disabled:bg-red-800 disabled:cursor-not-allowed text-white text-sm font-bold transition-colors">@(_deleting ? "Eliminando..." : "Eliminar")</button>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<TenantMessage>? _tenants;
    private string _newTenantName = string.Empty;
    private bool _creating;
    private string? _createError;
    private bool _showDeleteConfirm;
    private TenantMessage? _tenantToDelete;
    private bool _deleting;
    private string? _deletingId;
    private bool _localIsSuperAdmin;

    // ERP config modal
    private bool _showConfig;
    private CompanyStatusResponse? _status;
    private VerifyConnectionResponse? _verifyResult;
    private ErpConfigForm _form = new();
    private bool _showKey;
    private bool _saving;
    private bool _verifying;
    private bool _syncing;
    private string _msg = "";
    private bool _msgOk;
    private string _activeTenantId = "";

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;
        var cached = await JS.InvokeAsync<string>("localStorage.getItem", "isSuperAdmin");
        _localIsSuperAdmin = cached == "1";
        if ((State.IsSuperAdmin || _localIsSuperAdmin) && _tenants == null)
            await LoadTenants();
    }

    private async Task LoadTenants()
    {
        try
        {
            var response = await GrpcClient.GetAllTenantsAsync(new Empty());
            _tenants = response.Tenants.ToList();
        }
        catch (Exception ex) { Console.WriteLine($"Error loading tenants: {ex.Message}"); }
    }

    private async Task CreateTenant()
    {
        if (string.IsNullOrWhiteSpace(_newTenantName)) { _createError = "El nombre de la empresa es requerido."; return; }
        _creating = true; _createError = null;
        try
        {
            await GrpcClient.CreateTenantAsync(new CreateTenantRequest { Name = _newTenantName });
            _newTenantName = string.Empty;
            await LoadTenants();
        }
        catch (Exception ex) { _createError = ex.Message; }
        finally { _creating = false; }
    }

    private void ConfirmDelete(TenantMessage tenant) { _tenantToDelete = tenant; _showDeleteConfirm = true; }

    private async Task DeleteTenant()
    {
        if (_tenantToDelete == null) return;
        _deleting = true; _deletingId = _tenantToDelete.Id;
        try
        {
            await GrpcClient.DeleteTenantAsync(new DeleteEntityRequest { Id = _tenantToDelete.Id });
            _showDeleteConfirm = false; _tenantToDelete = null;
            await LoadTenants();
        }
        catch (Exception ex) { Console.WriteLine($"Error deleting: {ex.Message}"); }
        finally { _deleting = false; _deletingId = null; }
    }

    // --- ERP Config ---
    private async Task OpenConfig(TenantMessage t)
    {
        _activeTenantId = t.Id; _verifyResult = null; _msg = ""; _showKey = false;
        try { _status = await GrpcClient.GetCompanyStatusAsync(new GetCompanyStatusRequest { TenantId = t.Id }); }
        catch { _status = new CompanyStatusResponse { TenantName = t.Name }; }
        _form = new ErpConfigForm { TenantName = _status.TenantName, GestorDatabaseId = _status.GestorDatabaseId, BaseUrl = string.IsNullOrWhiteSpace(_status.BaseUrl) ? "https://api.gestormax.com" : _status.BaseUrl, ApiKey = "" };
        _showConfig = true;
    }

    private void CloseConfig() { _showConfig = false; _status = null; _verifyResult = null; }

    private async Task SaveConfig()
    {
        if (string.IsNullOrWhiteSpace(_form.TenantName)) { _msg = "La razón social es obligatoria."; _msgOk = false; return; }
        if (_form.GestorDatabaseId <= 0) { _msg = "El Database ID debe ser un número positivo."; _msgOk = false; return; }
        if (string.IsNullOrWhiteSpace(_form.BaseUrl)) { _msg = "La URL base es obligatoria."; _msgOk = false; return; }
        _saving = true; _msg = "Guardando configuración y sincronizando catálogos..."; _msgOk = true; StateHasChanged();
        try
        {
            var res = await GrpcClient.SaveCompanyConfigurationAsync(new SaveCompanyConfigurationRequest { TenantId = _activeTenantId, TenantName = _form.TenantName, ApiKey = _form.ApiKey ?? "", GestorDatabaseId = _form.GestorDatabaseId, BaseUrl = _form.BaseUrl });
            _msg = res.Success ? "Configuración guardada. Sincronización completada." : res.Message; _msgOk = res.Success;
            if (res.Success) { _status = await GrpcClient.GetCompanyStatusAsync(new GetCompanyStatusRequest { TenantId = _activeTenantId }); _form.ApiKey = ""; await LoadTenants(); }
        }
        catch (Exception ex) { _msg = $"Error: {ex.Message}"; _msgOk = false; }
        finally { _saving = false; StateHasChanged(); }
    }

    private async Task VerifyConnection()
    {
        _verifying = true; _verifyResult = null; StateHasChanged();
        try { _verifyResult = await GrpcClient.VerifyConnectionAsync(new VerifyConnectionRequest { TenantId = _activeTenantId }); _status = await GrpcClient.GetCompanyStatusAsync(new GetCompanyStatusRequest { TenantId = _activeTenantId }); }
        catch (Exception ex) { _verifyResult = new VerifyConnectionResponse { Success = false, Message = ex.Message }; }
        finally { _verifying = false; StateHasChanged(); }
    }

    private async Task TriggerSync()
    {
        _syncing = true; StateHasChanged();
        try { var res = await GrpcClient.TriggerCatalogSyncAsync(new TriggerSyncRequest { TenantId = _activeTenantId }); _msg = res.Success ? "Sincronización completada." : res.Message; _msgOk = res.Success; _status = await GrpcClient.GetCompanyStatusAsync(new GetCompanyStatusRequest { TenantId = _activeTenantId }); await LoadTenants(); }
        catch (Exception ex) { _msg = $"Error de sync: {ex.Message}"; _msgOk = false; }
        finally { _syncing = false; StateHasChanged(); }
    }

    private static (string, string) GetStatusBadge(TenantMessage t)
    {
        if (!t.HasErpConfig) return ("border-border-dark text-text-disabled", "link_off");
        var s = t.StatusSummary ?? "";
        if (s.Contains("Operativo", StringComparison.OrdinalIgnoreCase)) return ("border-green-700 text-green-400 bg-green-900/20", "check_circle");
        if (s.Contains("Error de conexión", StringComparison.OrdinalIgnoreCase)) return ("border-red-700 text-red-400 bg-red-900/20", "wifi_off");
        if (s.Contains("Error de sincro", StringComparison.OrdinalIgnoreCase)) return ("border-orange-700 text-orange-400 bg-orange-900/20", "sync_problem");
        if (s.Contains("Configurado", StringComparison.OrdinalIgnoreCase)) return ("border-blue-700 text-blue-400 bg-blue-900/20", "settings");
        return ("border-border-dark text-text-disabled", "help");
    }

    private static string FormatDate(string iso)
    {
        if (DateTimeOffset.TryParse(iso, out var dt)) return dt.ToLocalTime().ToString("dd/MM/yy HH:mm");
        return iso;
    }

    private class ErpConfigForm
    {
        public string TenantName { get; set; } = "";
        public string? ApiKey { get; set; }
        public int GestorDatabaseId { get; set; }
        public string BaseUrl { get; set; } = "https://api.gestormax.com";
    }

    public void Dispose() { State.OnChange -= StateHasChanged; }
}
