@page "/balance"
@using GestorGanadero.Client.Services
@using GestorGanadero.Grpc.V1
@using Google.Protobuf.WellKnownTypes
@using Microsoft.AspNetCore.Components.Web
@inject AppStateContainer State
@inject LivestockService.LivestockServiceClient GrpcClient
@implements IDisposable

<div class="module-header">
    <h1>Balance de Existencias</h1>
</div>

<div class="filters-bar card">
    <div class="filter-group">
        <label>Desde</label>
        <input type="date" @bind="StartDate" />
    </div>
    <div class="filter-group">
        <label>Hasta</label>
        <input type="date" @bind="EndDate" />
    </div>
    
    <div class="filter-group">
        <label>Campo</label>
        <select @bind="selectedFieldId">
            <option value="">Todos los campos</option>
            @if (fields != null)
            {
                foreach (var f in fields)
                {
                    <option value="@f.Id">@f.Name</option>
                }
            }
        </select>
    </div>

    <div class="filter-group">
        <label>Modalidad</label>
        <select @bind="categoryView">
            <option value="cliente">Vista Cliente</option>
            <option value="gestor">Vista Gestor</option>
        </select>
    </div>

    <div class="filter-actions">
        <button class="btn-consultar" @onclick="FetchBalance" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="spinner"></span>
            }
            Consultar
        </button>
    </div>
</div>

@if (isLoading)
{
    <div class="loader-container">
        <div class="spinner-large"></div>
        <p>Cargando balance...</p>
    </div>
}
else if (balanceReport != null)
{
    @* Prompt 2.2 will implement the table here *@
    <div class="mt-4">
        <GestorGanadero.Client.Components.Balance.BalanceTreeTable Items="@balanceReport.Items.ToList()" />
    </div>
}
else
{
    <div class="empty-state">
        <p class="text-secondary">Seleccione los filtros y presione "Consultar" para ver los datos.</p>
    </div>
}

@* Styles moved to Balance.razor.css *@

@code {
    private List<FieldMessage>? fields;
    private string selectedFieldId = "";
    private string categoryView = "cliente";
    private bool isLoading = false;
    private BalanceReport? balanceReport;

    private DateTime StartDate
    {
        get => State.ActiveDateRange?.Start ?? DateTime.Today.AddMonths(-1);
        set 
        {
            if (State.ActiveDateRange == null) State.ActiveDateRange = new DateRange();
            State.ActiveDateRange.Start = value;
        }
    }

    private DateTime EndDate
    {
        get => State.ActiveDateRange?.End ?? DateTime.Today;
        set 
        {
            if (State.ActiveDateRange == null) State.ActiveDateRange = new DateRange();
            State.ActiveDateRange.End = value;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;
        
        if (State.ActiveDateRange == null)
        {
            State.ActiveDateRange = new DateRange 
            { 
                Start = DateTime.Today.AddMonths(-1), 
                End = DateTime.Today 
            };
        }

        await LoadFields();
    }

    private async Task LoadFields()
    {
        try
        {
            if (string.IsNullOrEmpty(State.ActiveTenantId)) return;

            var response = await GrpcClient.GetFieldsAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId });
            fields = response.Fields.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading fields: {ex.Message}");
        }
    }

    private async Task FetchBalance()
    {
        if (string.IsNullOrEmpty(State.ActiveTenantId)) return;

        isLoading = true;
        balanceReport = null;
        StateHasChanged();

        try
        {
            var request = new GetBalanceRequest
            {
                TenantId = State.ActiveTenantId,
                Date = Timestamp.FromDateTime(EndDate.ToUniversalTime()),
                FieldId = selectedFieldId,
                CategoryView = categoryView
            };

            balanceReport = await GrpcClient.GetBalanceAsync(request);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching balance: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }
}
