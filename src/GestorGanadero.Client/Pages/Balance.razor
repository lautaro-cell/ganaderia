@page "/reportes/balance"
@using GestorGanadero.Client.Services
@using GestorGanadero.Services.Reporting.Contracts
@using GestorGanadero.Services.Catalog.Contracts
@using Google.Protobuf.WellKnownTypes
@inject AppStateContainer State
@inject ReportingService.ReportingServiceClient GrpcClient
@inject GestorGanadero.Client.Catalog.CatalogClientService CatalogSvc
@implements IDisposable

<div class="flex flex-col gap-6 p-6">
    <!-- Header -->
    <div class="flex justify-between items-start">
        <div class="flex flex-col gap-1">
            <h1 class="text-3xl font-black tracking-tight text-white m-0">Balance Contable</h1>
            <p class="text-text-secondary text-sm">Saldos contables por plan, centro de costo, cuenta y categoría. Stock solo en Activo.</p>
        </div>
        <div class="flex gap-3">
            <button class="bg-surface-dark border border-border-dark text-white rounded-lg px-4 py-2 text-sm font-bold flex items-center gap-2 hover:bg-border-dark transition-colors">
                <span class="material-symbols-outlined text-[18px]">print</span> Imprimir
            </button>
            <button class="bg-surface-dark border border-border-dark text-white rounded-lg px-4 py-2 text-sm font-bold flex items-center gap-2 hover:bg-border-dark transition-colors">
                <span class="material-symbols-outlined text-[18px]">download</span> Exportar CSV
            </button>
        </div>
    </div>

    <!-- Filters Card -->
    <div class="bg-surface-dark border border-border-dark rounded-2xl p-6 shadow-xl shadow-black/20">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
            <label class="flex flex-col gap-2">
                <span class="text-xs font-bold text-text-secondary uppercase tracking-widest">Periodo Contable</span>
                <select class="w-full bg-background-main border border-border-input rounded-lg px-4 py-2.5 text-white text-sm outline-none focus:ring-1 focus:ring-primary">
                    <option>Todos los periodos</option>
                </select>
            </label>

            <label class="flex flex-col gap-2">
                <span class="text-xs font-bold text-text-secondary uppercase tracking-widest">Modalidad</span>
                <div class="flex bg-background-main p-1 rounded-lg border border-border-input">
                    <button class="flex-1 px-4 py-1.5 text-xs font-bold rounded-md bg-transparent text-text-secondary hover:text-white transition-colors">Mes</button>
                    <button class="flex-1 px-4 py-1.5 text-xs font-bold rounded-md bg-primary text-white transition-colors">Acumulado</button>
                </div>
            </label>

            <label class="flex flex-col gap-2">
                <span class="text-xs font-bold text-text-secondary uppercase tracking-widest">Buscar</span>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-text-secondary text-sm">search</span>
                    <input type="text" class="w-full bg-background-main border border-border-input rounded-lg pl-10 pr-4 py-2.5 text-white text-sm outline-none focus:ring-1 focus:ring-primary" placeholder="Cuenta, campo o categoría..." />
                </div>
            </label>

            <label class="flex flex-col gap-2">
                <span class="text-xs font-bold text-text-secondary uppercase tracking-widest">Campo</span>
                <select @bind="_fieldId" class="w-full bg-background-main border border-border-input rounded-lg px-4 py-2.5 text-white text-sm outline-none focus:ring-1 focus:ring-primary">
                    <option value="">Todos los campos</option>
                    @if (_fields != null) { @foreach (var f in _fields) { <option value="@f.Id">@f.Name</option> } }
                </select>
            </label>
        </div>

        <div class="pt-6 border-t border-border-dark flex justify-between items-center">
            <label class="flex flex-col gap-2">
                <span class="text-xs font-bold text-text-secondary uppercase tracking-widest">Vista Categoría</span>
                <div class="flex bg-background-main p-1 rounded-lg border border-border-input">
                    <button class="px-6 py-1.5 text-xs font-bold rounded-md @(_view == "cliente" ? "bg-primary text-white" : "bg-transparent text-text-secondary hover:text-white")" @onclick='() => _view = "cliente"'>Cliente</button>
                    <button class="px-6 py-1.5 text-xs font-bold rounded-md @(_view == "gestor" ? "bg-primary text-white" : "bg-transparent text-text-secondary hover:text-white")" @onclick='() => _view = "gestor"'>Gestor</button>
                </div>
            </label>
            <button class="bg-primary hover:bg-primary-dark text-white rounded-lg px-8 py-2.5 text-sm font-bold shadow-lg shadow-primary/20 transition-all" @onclick="FetchBalance" disabled="@_loading">
                @if (_loading) { <span class="animate-spin rounded-full h-4 w-4 border-t-2 border-b-2 border-white"></span> }
                Consultar
            </button>
        </div>
    </div>

    <!-- Results Table -->
    <div class="bg-surface-dark border border-border-dark rounded-2xl shadow-xl shadow-black/20 overflow-hidden">
        @if (_loading)
        {
            <div class="flex justify-center py-16">
                <div class="animate-spin rounded-full h-10 w-10 border-t-2 border-b-2 border-primary"></div>
            </div>
        }
        else if (_report == null || !_report.Items.Any())
        {
            <div class="flex flex-col items-center justify-center py-16 text-center text-text-secondary">
                <span class="material-symbols-outlined text-5xl mb-4">analytics</span>
                <p class="text-white text-lg font-bold">No hay datos para los filtros seleccionados</p>
                <p class="text-sm">Ajusta los filtros para visualizar la información.</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm">
                    <thead class="bg-background-main border-b border-border-dark text-text-secondary uppercase text-[10px] tracking-widest">
                        <tr>
                            <th class="px-6 py-4 font-bold">Campo</th>
                            <th class="px-6 py-4 font-bold">Categoría</th>
                            <th class="px-6 py-4 font-bold">Actividad</th>
                            <th class="px-6 py-4 font-bold text-right">Cabezas</th>
                            <th class="px-6 py-4 font-bold text-right">Total KG</th>
                            <th class="px-6 py-4 font-bold text-right">KG/Cab</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-dark">
                        @foreach (var item in _report.Items)
                        {
                            <tr class="hover:bg-[#271c1c] transition-colors">
                                <td class="px-6 py-4 text-white font-bold">@item.FieldName</td>
                                <td class="px-6 py-4 text-text-body">@item.CategoryName</td>
                                <td class="px-6 py-4"><span class="px-2 py-1 rounded-md bg-border-dark text-white text-xs">@item.ActivityName</span></td>
                                <td class="px-6 py-4 text-right text-white font-mono font-bold">@item.HeadCount</td>
                                <td class="px-6 py-4 text-right text-white font-mono font-bold">@item.TotalWeight.ToString("N1")</td>
                                <td class="px-6 py-4 text-right text-white font-mono font-bold">@((item.HeadCount > 0 ? item.TotalWeight / item.HeadCount : 0).ToString("N2"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<FieldMessage>? _fields;
    private string _fieldId = "";
    private string _view = "cliente";
    private bool _loading;
    private BalanceReport? _report;

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;
        await LoadFields();
    }

    private async Task LoadFields()
    {
        if (string.IsNullOrEmpty(State.ActiveTenantId)) return;
        try
        {
            var r = await CatalogSvc.GetFieldsAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId });
            _fields = r.Data?.Fields.ToList() ?? new();
        }
        catch { }
    }

    private async Task FetchBalance()
    {
        if (string.IsNullOrEmpty(State.ActiveTenantId)) return;
        _loading = true;
        _report = null;
        StateHasChanged();
        try
        {
            // Placeholder for real logic (GrpcClient needs to be properly configured/imported if not already)
            // Mocking for now to match UI update request
            _report = new BalanceReport(); 
            // _report = await GrpcClient.GetBalanceAsync(...);
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
        finally { _loading = false; StateHasChanged(); }
    }

    public void Dispose() => State.OnChange -= StateHasChanged;
}
