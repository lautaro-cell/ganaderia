@page "/admin"
@using GestorGanadero.Client.Components.Admin
@using GestorGanadero.Client.Services
@inject AppStateContainer State
@implements IDisposable

<div class="page-header">
    <h1>Administración</h1>
    <span class="subtitle">Configura campos, actividades, categorías, lotes y usuarios</span>
</div>

<div class="split-view" style="min-height: calc(100vh - 200px);">
    <aside class="master-panel">
        <div style="padding: 16px 16px 8px;">
            <div style="font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:var(--text-muted);">Secciones</div>
        </div>
        <button class="master-item @(_section == Section.Campos ? "selected" : "")" @onclick="() => _section = Section.Campos">
            <div class="flex items-center gap-sm">
                <span class="material-icons" style="font-size:20px; color:var(--text-muted);">terrain</span>
                <span style="font-size:0.875rem; font-weight:500;">Campos</span>
            </div>
            <span class="material-icons" style="font-size:16px; color:var(--text-muted);">chevron_right</span>
        </button>
        <button class="master-item @(_section == Section.Actividades ? "selected" : "")" @onclick="() => _section = Section.Actividades">
            <div class="flex items-center gap-sm">
                <span class="material-icons" style="font-size:20px; color:var(--text-muted);">assignment</span>
                <span style="font-size:0.875rem; font-weight:500;">Actividades</span>
            </div>
            <span class="material-icons" style="font-size:16px; color:var(--text-muted);">chevron_right</span>
        </button>
        <button class="master-item @(_section == Section.Categorias ? "selected" : "")" @onclick="() => _section = Section.Categorias">
            <div class="flex items-center gap-sm">
                <span class="material-icons" style="font-size:20px; color:var(--text-muted);">category</span>
                <span style="font-size:0.875rem; font-weight:500;">Categorías</span>
            </div>
            <span class="material-icons" style="font-size:16px; color:var(--text-muted);">chevron_right</span>
        </button>
        <button class="master-item @(_section == Section.Lotes ? "selected" : "")" @onclick="() => _section = Section.Lotes">
            <div class="flex items-center gap-sm">
                <span class="material-icons" style="font-size:20px; color:var(--text-muted);">grid_view</span>
                <span style="font-size:0.875rem; font-weight:500;">Lotes</span>
            </div>
            <span class="material-icons" style="font-size:16px; color:var(--text-muted);">chevron_right</span>
        </button>
        <button class="master-item @(_section == Section.Plantillas ? "selected" : "")" @onclick="() => _section = Section.Plantillas">
            <div class="flex items-center gap-sm">
                <span class="material-icons" style="font-size:20px; color:var(--text-muted);">settings_suggest</span>
                <span style="font-size:0.875rem; font-weight:500;">Plantillas de Eventos</span>
            </div>
            <span class="material-icons" style="font-size:16px; color:var(--text-muted);">chevron_right</span>
        </button>
        <div style="height:1px; background:var(--border); margin:8px 16px;"></div>
        <button class="master-item @(_section == Section.Usuarios ? "selected" : "")" @onclick="() => _section = Section.Usuarios">
            <div class="flex items-center gap-sm">
                <span class="material-icons" style="font-size:20px; color:var(--text-muted);">people</span>
                <span style="font-size:0.875rem; font-weight:500;">Usuarios</span>
            </div>
            <span class="material-icons" style="font-size:16px; color:var(--text-muted);">chevron_right</span>
        </button>
    </aside>

    <div class="detail-panel">
        @switch (_section)
        {
            case Section.Campos: <FieldsAdmin /> break;
            case Section.Actividades: <ActivitiesAdmin /> break;
            case Section.Categorias: <CategoriesAdmin /> break;
            case Section.Lotes: <LotesAdmin /> break;
            case Section.Plantillas: <TemplatesAdmin /> break;
            case Section.Usuarios: <UsersAdmin /> break;
        }
    </div>
</div>

@code {
    private enum Section { Campos, Actividades, Categorias, Lotes, Plantillas, Usuarios }
    private Section _section = Section.Campos;

    protected override void OnInitialized() => State.OnChange += StateHasChanged;
    public void Dispose() => State.OnChange -= StateHasChanged;
}
