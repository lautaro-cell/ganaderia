@using GestorGanadero.Services.Identity.Contracts
@if (IsOpen && User != null)
{
  <div class="drawer" style="position:fixed; right:0; top:0; bottom:0; width:420px; background:#111; border-left:1px solid #333; padding:16px; overflow:auto;">
    <h3>Editar Usuario</h3>
    <div>
      <label>Email</label>
      <input @bind="User.Email" style="width:100%; padding:6px; margin-bottom:8px;" />
    </div>
    <div>
      <label>Nombre</label>
      <input @bind="User.Name" style="width:100%; padding:6px; margin-bottom:8px;" />
    </div>
    <div>
      <label>Activo</label>
      <input type="checkbox" @bind="User.IsActive" />
    </div>
    <button class="btn" style="margin-top:12px; background:#C0392B; color:#fff; padding:8px 12px; border-radius:6px; border:none;" @onclick="Save">Guardar</button>
  </div>
}

@code {
  [Parameter] public bool IsOpen { get; set; }
  [Parameter] public UserMessage? User { get; set; }
  [Parameter] public EventCallback OnClose { get; set; }
  [Parameter] public EventCallback<UserMessage> OnUpdateAsync { get; set; }
  private async Task Save()
  {
    if (User != null)
    {
      await OnUpdateAsync.InvokeAsync(User);
      if (OnClose.HasDelegate) await OnClose.InvokeAsync();
    }
  }
}
