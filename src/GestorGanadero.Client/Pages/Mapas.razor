@page "/maps"
@using GestorGanadero.Client.Services
@using GestorGanadero.Services.Catalog.Contracts
@inject AppStateContainer State
@inject CatalogService.CatalogServiceClient GrpcClient
@inject IJSRuntime JS
@implements IDisposable

<div class="flex flex-col gap-6">
    <!-- Header -->
    <div class="flex flex-col gap-1">
        <h1 class="text-white text-3xl font-black leading-tight tracking-tight">Mapas y Catastro</h1>
        <p class="text-text-secondary text-sm">Gestión geográfica de campos y parcelas.</p>
    </div>

    <!-- Map Container -->
    <div class="bg-surface-dark border border-border-dark rounded-2xl overflow-hidden shadow-xl shadow-black/20 relative group">
        <!-- Map Controls (Floating) -->
        <div class="absolute top-4 left-4 z-[40] w-full max-w-[280px] pointer-events-none">
            <div class="bg-background-main/90 backdrop-blur-md border border-border-dark rounded-2xl p-4 shadow-2xl pointer-events-auto flex flex-col gap-4">
                <div class="flex flex-col gap-2">
                    <label class="text-[10px] font-black text-text-secondary uppercase tracking-widest px-1">Campo para dibujar</label>
                    <div class="relative">
                        <select @bind="_activeFieldId" class="w-full bg-surface-darker border border-border-dark rounded-xl px-4 h-11 text-sm text-white focus:ring-primary outline-none cursor-pointer appearance-none">
                            <option value="">Seleccione un campo...</option>
                            @if (_fields != null)
                            {
                                @foreach (var f in _fields)
                                {
                                    <option value="@f.Id">@f.Name</option>
                                }
                            }
                        </select>
                        <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-text-secondary pointer-events-none">expand_more</span>
                    </div>
                    <p class="text-[10px] text-text-disabled italic px-1">Seleccione un campo antes de usar la herramienta de dibujo.</p>
                </div>

                @if (!string.IsNullOrEmpty(_statusMsg))
                {
                    <div class="flex items-center gap-2 p-3 rounded-lg @(_statusOk ? "bg-emerald-500/10 text-emerald-400 border border-emerald-500/20" : "bg-red-500/10 text-red-400 border border-red-500/20") text-[11px] font-medium animate-in fade-in slide-in-from-top-1">
                        <span class="material-symbols-outlined text-sm">@(_statusOk ? "check_circle" : "error")</span>
                        <span>@_statusMsg</span>
                    </div>
                }
            </div>
        </div>

        <!-- Map Element -->
        <div id="map" class="h-[70vh] w-full z-[1]"></div>
        
        <!-- Legend Overlay -->
        <div class="absolute bottom-4 right-4 z-[40] bg-background-main/80 backdrop-blur-sm border border-border-dark rounded-xl px-3 py-2 text-[10px] text-text-secondary flex items-center gap-4">
            <div class="flex items-center gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-primary/40 border border-primary"></span>
                <span>Parcelas</span>
            </div>
            <div class="flex items-center gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-blue-500/40 border border-blue-500"></span>
                <span>Sede Central</span>
            </div>
        </div>
    </div>
</div>

@code {
    private List<FieldMessage>? _fields;
    private string _activeFieldId = "";
    private string _statusMsg = "";
    private bool _statusOk;
    private DotNetObjectReference<Mapas>? _objRef;

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;
        await LoadFields();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("initMap", "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png", _objRef);
        }
    }

    private async Task LoadFields()
    {
        if (string.IsNullOrEmpty(State.ActiveTenantId)) return;
        try
        {
            var r = await GrpcClient.GetFieldsAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId });
            _fields = r.Fields.ToList();
        }
        catch { }
    }

    [JSInvokable]
    public async Task OnPolygonDrawn(string geojson)
    {
        if (string.IsNullOrEmpty(_activeFieldId))
        {
            _statusOk = false;
            _statusMsg = "Debe seleccionar un campo antes de guardar.";
            StateHasChanged();
            return;
        }
        
        _statusOk = true;
        _statusMsg = "Geometría capturada. (Guardado pendiente)";
        StateHasChanged();
        
        await Task.Delay(3000);
        _statusMsg = "";
        StateHasChanged();
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
        _objRef?.Dispose();
    }
}
