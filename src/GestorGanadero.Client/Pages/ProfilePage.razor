@page "/perfil"
@using GestorGanadero.Client.Identity
@using GestorGanadero.Services.Identity.Contracts
@using GestorGanadero.Client.Shared
@using GestorGanadero.Client.Services
@inject IdentityClientService IdentityClientService
@inject AppStateContainer State
@inject IJSRuntime JSRuntime

<PageHeader Title="Mi Perfil" />

<div class="main-container flex gap-lg">
  <div class="card" style="width:280px; text-align:center; padding: 32px;">
    <div class="user-avatar" style="width:120px; height:120px; font-size:40px; margin: 0 auto 16px;">
      @((Profile?.Name?.Length > 0) ? Profile.Name.Substring(0, 1).ToUpper() : "?")
    </div>
    <h3 class="mb-xs">@Profile?.Name</h3>
    <span class="badge badge-primary">@Profile?.Role</span>
  </div>

  <div style="flex:1;">
    @if (Profile != null)
    {
      <div class="card">
        <div class="card-header"><h3>Información de Cuenta</h3></div>
        <div class="card-body">
            <div class="form-group"><label>Email</label><div class="text-primary">@Profile.Email</div></div>
            <div class="form-group">
                <label>Establecimiento Activo</label>
                <div class="flex gap-md items-center mt-xs">
                    <select @onchange="OnTenantChange" value="@SelectedTenantId" class="form-select">
                        @if (Tenants != null)
                        {
                            @foreach (var t in Tenants.Tenants)
                            {
                                <option value="@t.Id">@t.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
      </div>
    }
    else if (HasError)
    {
      <div class="alert alert-danger">Error al cargar el perfil.</div>
    }
    else
    {
      <div class="loading-container"><div class="spinner spinner-lg"></div></div>
    }
  </div>
</div>

@code {
  private UserProfile? Profile;
  private TenantList? Tenants;
  private string SelectedTenantId = string.Empty;
  private bool HasError = false;

  protected override async Task OnInitializedAsync()
  {
    var profRes = await IdentityClientService.GetMyProfileAsync();
    if (profRes.Success) Profile = profRes.Data; else HasError = true;

    var tenRes = await IdentityClientService.GetAvailableTenantsAsync();
    if (tenRes.Success) Tenants = tenRes.Data;

    SelectedTenantId = Profile?.ActiveTenantId ?? string.Empty;
  }

  private async Task OnTenantChange(ChangeEventArgs e)
  {
    var t = e.Value?.ToString();
    if (!string.IsNullOrEmpty(t))
    {
      State.ActiveTenantId = t;
      await JSRuntime.InvokeVoidAsync("location.reload");
    }
  }
}

