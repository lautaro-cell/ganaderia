@page "/ledger"
@using GestorGanadero.Client.Services
@using GestorGanadero.Grpc.V1
@using Google.Protobuf.WellKnownTypes
@using global::Grpc.Core
@inject AppStateContainer State
@inject LivestockService.LivestockServiceClient GrpcClient
@implements IDisposable

<div class="module-header">
    <h1>Libro Mayor</h1>
</div>

<div class="ledger-layout">
    <!-- Sección Sincronización (Prompt 4.2) -->
    <section class="sync-console card mb-4">
        <div class="card-header">
            <h3>Pendiente de Sincronización ERP</h3>
            <button class="btn-sync" @onclick="SyncSelected" disabled="@(!selectedPendingIds.Any() || isSyncing)">
                @if (isSyncing)
                {
                    <span class="spinner"></span>
                }
                Sincronizar seleccionados (@selectedPendingIds.Count)
            </button>
        </div>
        
        <div class="table-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        <th width="40"><input type="checkbox" @onchange="ToggleSelectAllPending" /></th>
                        <th>Fecha</th>
                        <th>Descripción</th>
                        <th class="text-end">Importe</th>
                    </tr>
                </thead>
                <tbody>
                    @if (pendingEntries != null && pendingEntries.Any())
                    {
                        foreach (var entry in pendingEntries)
                        {
                            <tr>
                                <td>
                                    <input type="checkbox" 
                                           checked="@selectedPendingIds.Contains(entry.Id)" 
                                           @onchange="@(e => TogglePendingSelection(entry.Id, e.Value))" />
                                </td>
                                <td>@entry.Date.ToDateTime().ToShortDateString()</td>
                                <td>@entry.Description</td>
                                <td class="text-end">@entry.Amount.ToString("C2")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-secondary py-3">No hay asientos pendientes.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if (!string.IsNullOrEmpty(syncMessage))
        {
            <div class="toast-inline @(syncSuccess ? "success" : "error")">
                @(syncSuccess ? "✓ " : "✕ ") @syncMessage
            </div>
        }
    </section>

    <!-- Sección Listado Mayor (Prompt 4.1) -->
    <section class="ledger-list card">
        <div class="card-header">
            <h3>Movimientos del Mayor</h3>
            <div class="pagination-controls">
                <button class="btn-secondary" @onclick="PrevPage" disabled="@(pageIndex <= 0 || isLoadingLedger)">Anterior</button>
                <span class="page-info">Página @(pageIndex + 1)</span>
                <button class="btn-secondary" @onclick="NextPage" disabled="@(ledgerEntries.Count < pageSize || isLoadingLedger)">Siguiente</button>
            </div>
        </div>

        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Descripción</th>
                        <th>Tipo</th>
                        <th class="text-end">Cabezas</th>
                        <th class="text-end">KG</th>
                        <th class="text-end">Importe</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @if (isLoadingLedger)
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <div class="spinner-large"></div>
                                <p class="mt-2 text-secondary">Cargando movimientos...</p>
                            </td>
                        </tr>
                    }
                    else if (ledgerEntries.Any())
                    {
                        foreach (var entry in ledgerEntries)
                        {
                            <tr>
                                <td>@entry.Date.ToDateTime().ToShortDateString()</td>
                                <td>@entry.Description</td>
                                <td>@entry.EntryType</td>
                                <td class="text-end">@entry.HeadCount</td>
                                <td class="text-end">@entry.WeightKg</td>
                                <td class="text-end">@entry.Amount.ToString("C2")</td>
                                <td>
                                    <span class="status-badge @entry.Status.ToLower()">@entry.Status</span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-secondary py-4">No se encontraron movimientos.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

<style>
    .ledger-layout {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 16px;
        margin-bottom: 16px;
        border-bottom: 1px solid var(--border);
    }

    .btn-sync {
        background-color: var(--accent);
        color: white;
        padding: 8px 16px;
        border-radius: var(--radius-sm);
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .pagination-controls {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .page-info {
        font-size: 0.85rem;
        color: var(--text-secondary);
        font-weight: 500;
    }

    .table-scroll {
        max-height: 300px;
        overflow-y: auto;
    }

    .status-badge {
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
    }
    .status-badge.synced { background: rgba(0, 255, 0, 0.1); color: #00ff00; }
    .status-badge.draft { background: rgba(255, 255, 255, 0.05); color: var(--text-secondary); }

    .toast-inline {
        margin-top: 16px;
        padding: 10px 16px;
        border-radius: var(--radius-sm);
        font-size: 0.85rem;
        font-weight: 600;
    }
    .toast-inline.success { background: rgba(0, 255, 0, 0.1); color: #00ff00; border: 1px solid rgba(0, 255, 0, 0.2); }
    .toast-inline.error { background: rgba(255, 0, 0, 0.1); color: var(--accent); border: 1px solid rgba(255, 0, 0, 0.2); }

    .spinner {
        width: 14px;
        height: 14px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    .spinner-large {
        width: 32px;
        height: 32px;
        border: 3px solid var(--surface-2);
        border-top-color: var(--accent);
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin: 0 auto;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }
    
    .text-end { text-align: right !important; }
    .text-center { text-align: center !important; }
    .mb-4 { margin-bottom: 2rem; }
    .mt-2 { margin-top: 0.5rem; }
    .py-3 { padding-top: 1.5rem; padding-bottom: 1.5rem; }
    .py-4 { padding-top: 2rem; padding-bottom: 2rem; }
    .py-5 { padding-top: 3rem; padding-bottom: 3rem; }
</style>

@code {
    private List<LedgerEntry> ledgerEntries = new();
    private List<LedgerEntry> pendingEntries = new();
    private HashSet<string> selectedPendingIds = new();
    
    private int pageIndex = 0;
    private int pageSize = 50;
    private bool isLoadingLedger = false;
    private bool isSyncing = false;
    
    private string syncMessage = "";
    private bool syncSuccess = false;

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;
        await LoadAll();
    }

    private async Task LoadAll()
    {
        await LoadPendingSync();
        await LoadLedger();
    }

    private async Task LoadLedger()
    {
        if (string.IsNullOrEmpty(State.ActiveTenantId)) return;
        
        isLoadingLedger = true;
        ledgerEntries.Clear();
        StateHasChanged();

        try
        {
            var filter = new LedgerFilter 
            { 
                TenantId = State.ActiveTenantId, 
                PageIndex = pageIndex, 
                PageSize = pageSize 
            };

            using var call = GrpcClient.GetLedger(filter);
            
            // Requerimiento Prompt 4.1: await foreach del stream
            // ReadAllAsync ya viene en el namespace Grpc.Core con la mayoría de clientes.
            while (await call.ResponseStream.MoveNext(default))
            {
                var entry = call.ResponseStream.Current;
                ledgerEntries.Add(entry);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading ledger: {ex.Message}");
        }
        finally
        {
            isLoadingLedger = false;
            StateHasChanged();
        }
    }

    private async Task LoadPendingSync()
    {
        if (string.IsNullOrEmpty(State.ActiveTenantId)) return;
        try
        {
            var response = await GrpcClient.GetPendingSyncEventsAsync(new PendingSyncFilter { TenantId = State.ActiveTenantId });
            pendingEntries = response.Entries.ToList();
            selectedPendingIds.Clear();
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private async Task PrevPage()
    {
        if (pageIndex > 0)
        {
            pageIndex--;
            await LoadLedger();
        }
    }

    private async Task NextPage()
    {
        pageIndex++;
        await LoadLedger();
    }

    private void TogglePendingSelection(string id, object? isChecked)
    {
        if (isChecked is bool val && val)
            selectedPendingIds.Add(id);
        else
            selectedPendingIds.Remove(id);
    }

    private void ToggleSelectAllPending(ChangeEventArgs e)
    {
        bool selectAll = (bool)(e.Value ?? false);
        if (selectAll)
            selectedPendingIds = new HashSet<string>(pendingEntries.Select(x => x.Id));
        else
            selectedPendingIds.Clear();
    }

    private async Task SyncSelected()
    {
        if (!selectedPendingIds.Any()) return;
        
        isSyncing = true;
        syncMessage = "";
        StateHasChanged();

        try
        {
            var count = selectedPendingIds.Count;
            var request = new SyncRequest();
            request.EntryIds.AddRange(selectedPendingIds);

            var response = await GrpcClient.SyncToERPAsync(request);

            if (response.Count >= 0) // Si respondió, lo consideramos éxito
            {
                syncSuccess = true;
                syncMessage = $"{response.Count} asientos sincronizados correctamente.";
                await LoadAll();
            }
        }
        catch (Exception ex)
        {
            syncSuccess = false;
            syncMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSyncing = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }
}
