@page "/reportes/mayor-legacy"
@using GestorGanadero.Client.Services
@using GestorGanadero.Services.Reporting.Contracts
@using GestorGanadero.Services.Sync.Contracts
@using GestorGanadero.Client.Sync
@using Google.Protobuf.WellKnownTypes
@using global::Grpc.Core
@inject AppStateContainer State
@inject ReportingService.ReportingServiceClient GrpcClient
@inject SyncClientService SyncSvc
@implements IDisposable

<div class="flex flex-col gap-6">
    <!-- Header -->
    <div class="flex flex-wrap justify-between items-center gap-4">
        <div class="flex flex-col gap-1">
            <h1 class="text-white text-3xl font-black leading-tight tracking-tight">Libro Mayor</h1>
            <p class="text-text-secondary text-sm">Movimientos contables y sincronización con el ERP.</p>
        </div>
        <div class="flex items-center gap-3 bg-surface-dark p-2 rounded-xl border border-border-dark">
            <input type="date" @bind="_startDate" class="bg-background-main border border-border-dark rounded-lg px-3 py-1.5 text-xs text-white outline-none focus:border-primary" />
            <span class="text-text-disabled text-xs">—</span>
            <input type="date" @bind="_endDate" class="bg-background-main border border-border-dark rounded-lg px-3 py-1.5 text-xs text-white outline-none focus:border-primary" />
            <button class="p-2 hover:bg-surface-darker rounded-lg text-text-secondary hover:text-white transition-colors" @onclick="LoadAll">
                <span class="material-symbols-outlined text-lg">refresh</span>
            </button>
        </div>
    </div>

    <!-- Pending Sync Card -->
    <div class="bg-surface-dark border border-border-dark rounded-2xl overflow-hidden shadow-xl shadow-black/20">
        <div class="px-6 py-4 bg-surface-darker/50 border-b border-border-dark flex justify-between items-center">
            <h3 class="text-white font-bold flex items-center gap-2">
                <span class="material-symbols-outlined text-yellow-500">sync_problem</span>
                Pendientes de Sincronización
            </h3>
            <button class="flex items-center gap-2 px-4 py-2 rounded-lg bg-primary hover:bg-red-700 transition-colors text-white text-xs font-bold shadow-lg shadow-primary/20 disabled:opacity-50" 
                    @onclick="SyncSelected" disabled="@(!_pendingIds.Any() || _syncing)">
                @if (_syncing)
                {
                    <div class="animate-spin rounded-full h-3 w-3 border-b-2 border-white"></div>
                    <span>Sincronizando...</span>
                }
                else
                {
                    <span class="material-symbols-outlined text-sm">sync</span>
                    <span>Sincronizar (@_pendingIds.Count)</span>
                }
            </button>
        </div>

        @if (_pendingEntries == null)
        {
            <div class="flex flex-col items-center justify-center py-12 gap-3">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
                <span class="text-text-secondary text-xs">Buscando pendientes...</span>
            </div>
        }
        else if (!_pendingEntries.Any())
        {
            <div class="p-8 flex flex-col items-center justify-center text-center gap-2 opacity-50">
                <span class="material-symbols-outlined text-4xl text-emerald-500">check_circle</span>
                <p class="text-text-secondary text-sm font-bold">Todo al día</p>
                <p class="text-text-disabled text-xs">No hay asientos pendientes de sincronización.</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm border-collapse">
                    <thead class="bg-background-main text-text-secondary uppercase text-[10px] tracking-widest border-b border-border-dark">
                        <tr>
                            <th class="px-6 py-4 w-10"><input type="checkbox" @onchange="ToggleAll" class="rounded border-border-dark bg-background-main text-primary focus:ring-primary" /></th>
                            <th class="px-6 py-4">Fecha</th>
                            <th class="px-6 py-4">Descripción</th>
                            <th class="px-6 py-4 text-right">Importe</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-dark/30">
                        @foreach (var e in _pendingEntries)
                        {
                            <tr class="hover:bg-white/5 transition-colors">
                                <td class="px-6 py-4"><input type="checkbox" checked="@_pendingIds.Contains(e.Id)" @onchange="ev => ToggleId(e.Id, ev.Value)" class="rounded border-border-dark bg-background-main text-primary focus:ring-primary" /></td>
                                <td class="px-6 py-4 text-white">@e.Date.ToDateTime().ToString("dd/MM/yyyy")</td>
                                <td class="px-6 py-4 text-text-secondary">@e.Description</td>
                                <td class="px-6 py-4 text-right text-white font-mono">@e.Amount.ToString("C2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (!string.IsNullOrEmpty(_syncMsg))
        {
            <div class="m-6 p-4 rounded-xl @(_syncOk ? "bg-emerald-500/10 text-emerald-400 border border-emerald-500/20" : "bg-red-500/10 text-red-400 border border-red-500/20") text-sm flex items-center gap-3">
                <span class="material-symbols-outlined">@(_syncOk ? "check_circle" : "error")</span>
                <span>@_syncMsg</span>
            </div>
        }
    </div>

    <!-- Ledger Table -->
    <div class="bg-surface-dark border border-border-dark rounded-2xl overflow-hidden shadow-xl shadow-black/20">
        <div class="px-6 py-4 bg-surface-darker/50 border-b border-border-dark flex justify-between items-center">
            <h3 class="text-white font-bold flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">menu_book</span>
                Movimientos del Mayor
            </h3>
            <div class="flex items-center gap-2">
                <button class="p-2 hover:bg-surface-darker rounded-lg text-text-secondary disabled:opacity-30" @onclick="PrevPage" disabled="@(_page <= 0 || _loadingLedger)">
                    <span class="material-symbols-outlined">chevron_left</span>
                </button>
                <span class="text-xs font-bold text-white bg-surface-darker px-3 py-1 rounded-md border border-border-dark">Página @(_page + 1)</span>
                <button class="p-2 hover:bg-surface-darker rounded-lg text-text-secondary disabled:opacity-30" @onclick="NextPage" disabled="@(_ledger.Count < _pageSize || _loadingLedger)">
                    <span class="material-symbols-outlined">chevron_right</span>
                </button>
            </div>
        </div>

        @if (_loadingLedger && !_ledger.Any())
        {
            <div class="flex flex-col items-center justify-center py-20 gap-4">
                <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-primary"></div>
                <span class="text-text-secondary text-sm">Cargando movimientos...</span>
            </div>
        }
        else if (!_ledger.Any() && !_loadingLedger)
        {
            <div class="flex flex-col items-center justify-center py-20 text-center gap-3 opacity-40">
                <span class="material-symbols-outlined text-5xl">inbox</span>
                <p class="text-white text-lg font-bold">No se encontraron movimientos</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm border-collapse">
                    <thead class="bg-background-main text-text-secondary uppercase text-[10px] tracking-widest border-b border-border-dark">
                        <tr>
                            <th class="px-6 py-4">Fecha</th>
                            <th class="px-6 py-4">Descripción</th>
                            <th class="px-6 py-4">Tipo</th>
                            <th class="px-6 py-4 text-right">Cabezas</th>
                            <th class="px-6 py-4 text-right">Total KG</th>
                            <th class="px-6 py-4 text-right">Importe</th>
                            <th class="px-6 py-4 text-center">Estado</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-dark/30">
                        @foreach (var e in _ledger)
                        {
                            <tr class="hover:bg-white/5 transition-colors">
                                <td class="px-6 py-4 text-white">@e.Date.ToDateTime().ToString("dd MMM, yyyy")</td>
                                <td class="px-6 py-4">
                                    <div class="flex flex-col">
                                        <span class="text-white font-bold">@e.Description</span>
                                        <span class="text-[10px] text-text-disabled font-mono">CTA: @e.AccountCode</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-surface-darker text-text-secondary border border-border-dark">@e.EntryType</span>
                                </td>
                                <td class="px-6 py-4 text-right text-text-secondary font-mono">@(e.HeadCount > 0 ? e.HeadCount : "-")</td>
                                <td class="px-6 py-4 text-right text-text-secondary font-mono">@(double.TryParse(e.WeightKg, out var w) && w > 0 ? w.ToString("N1") : "-")</td>
                                <td class="px-6 py-4 text-right text-white font-mono font-bold">@e.Amount.ToString("C2")</td>
                                <td class="px-6 py-4 text-center">
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold @(e.Status.ToLower() == "synced" ? "bg-emerald-500/10 text-emerald-400 border border-emerald-500/20" : "bg-surface-darker text-text-disabled border border-border-dark")">
                                        @e.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<LedgerEntry> _ledger = new();
    private List<SyncEntry> _pendingEntries = new();
    private HashSet<string> _pendingIds = new();

    private DateTime _startDate = DateTime.Today.AddDays(-30);
    private DateTime _endDate = DateTime.Today.AddDays(1);
    private int _page = 0;
    private int _pageSize = 20;
    private bool _loadingLedger;
    private bool _syncing;
    private string _syncMsg = "";
    private bool _syncOk;

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;
        await LoadAll();
    }

    private async Task LoadAll()
    {
        if (string.IsNullOrEmpty(State.ActiveTenantId)) return;
        try
        {
            var r = await SyncSvc.GetPendingAsync(new PendingSyncFilter { TenantId = State.ActiveTenantId });
            _pendingEntries = r.Data?.Entries.ToList() ?? new();
            _pendingIds.Clear();
        }
        catch { }
        await LoadLedger();
    }

    private async Task LoadLedger()
    {
        if (string.IsNullOrEmpty(State.ActiveTenantId)) return;
        _loadingLedger = true;
        _ledger.Clear();
        StateHasChanged();

        try
        {
            var filter = new LedgerFilter 
            { 
                TenantId = State.ActiveTenantId, 
                PageIndex = _page, 
                PageSize = _pageSize,
                StartDate = Timestamp.FromDateTime(DateTime.SpecifyKind(_startDate, DateTimeKind.Utc)),
                EndDate = Timestamp.FromDateTime(DateTime.SpecifyKind(_endDate, DateTimeKind.Utc))
            };
            using var call = GrpcClient.GetLedger(filter);
            while (await call.ResponseStream.MoveNext(default))
            {
                _ledger.Add(call.ResponseStream.Current);
                StateHasChanged();
            }
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
        finally { _loadingLedger = false; StateHasChanged(); }
    }

    private async Task PrevPage() { if (_page > 0) { _page--; await LoadLedger(); } }
    private async Task NextPage() { _page++; await LoadLedger(); }

    private void ToggleId(string id, object? val) { if (val is bool b && b) _pendingIds.Add(id); else _pendingIds.Remove(id); }
    private void ToggleAll(ChangeEventArgs e) { if (e.Value is bool b && b) _pendingIds = new(_pendingEntries.Select(x => x.Id)); else _pendingIds.Clear(); }

    private async Task SyncSelected()
    {
        if (!_pendingIds.Any()) return;
        _syncing = true; _syncMsg = ""; StateHasChanged();
        try
        {
            var req = new SyncRequest();
            req.EntryIds.AddRange(_pendingIds);
            var r = await SyncSvc.SyncToERPAsync(req);
            if (r.Success && r.Data != null)
            {
                _syncOk = true;
                _syncMsg = $"{r.Data.Count} asientos sincronizados correctamente.";
                await LoadAll();
            }
            else
            {
                _syncOk = false;
                _syncMsg = r.Message;
            }
        }
        catch (Exception ex) { _syncOk = false; _syncMsg = $"Error: {ex.Message}"; }
        finally { _syncing = false; StateHasChanged(); }
    }

    public void Dispose() => State.OnChange -= StateHasChanged;
}
