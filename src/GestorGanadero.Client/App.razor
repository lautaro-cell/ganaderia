@using GestorGanadero.Client.Services
@inject IAuthService AuthService
@inject Microsoft.AspNetCore.Components.NavigationManager Navigation
@inject AppStateContainer State

<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)"/>
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(MainLayout)">
            <GestorGanadero.Client.Pages.NotFound />
        </LayoutView>
    </NotFound>
</Router>

@code {
    protected override async Task OnInitializedAsync()
    {
        await AuthService.LoadUserContextAsync();
        if (string.IsNullOrEmpty(State.ActiveTenantId) && !Navigation.Uri.Contains("/login"))
        {
            Navigation.NavigateTo("/login");
        }
    }
}
