@* Page header component - non-generic to simplify usage *@
<div class="page-header" style="padding:8px 0 12px 0; border-bottom:1px solid #2A2A2A; margin-bottom:8px;">
  <div style="font-family:var(--font-display); font-size:1.8em; color:white;">@Title</div>
  @if (Breadcrumb != null)
  {
    <div style="font-size:0.9em; color:#aaa;">@Breadcrumb</div>
  }
  <div class="actions" style="margin-top:6px;">
    @Actions
  </div>
</div>

@code {
  [Parameter] public string Title { get; set; } = "Página";
  [Parameter] public RenderFragment? Breadcrumb { get; set; }
  [Parameter] public RenderFragment? Actions { get; set; }
  [Parameter] public RenderFragment? ChildContent { get; set; }
}
