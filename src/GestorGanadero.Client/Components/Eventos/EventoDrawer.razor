@using GestorGanadero.Client.Services
@using GestorGanadero.Services.Operations.Contracts
@using GestorGanadero.Services.Common.Contracts
@using GestorGanadero.Services.Catalog.Contracts
@using Google.Protobuf.WellKnownTypes
@inject AppStateContainer State
@inject OperationsService.OperationsServiceClient GrpcClient
@inject GestorGanadero.Client.Catalog.CatalogClientService CatalogSvc

@if (SelectedTemplate != null)
{
    <div class="drawer-overlay" @onclick="HandleClose">
        <div class="drawer" @onclick:stopPropagation>
            <div class="drawer-header">
                <h2>Registrar @SelectedTemplate.Name</h2>
                <button class="btn-icon" @onclick="HandleClose">
                    <span class="material-icons">close</span>
                </button>
            </div>

            <div class="drawer-body">
                <div class="form-group">
                    <label>Fecha del Evento</label>
                    <input type="date" @bind="_eventDate" class="form-control" />
                </div>

                @if (SelectedTemplate.Fields.Contains("head_count"))
                {
                    <div class="form-group">
                        <label>Cantidad de Cabezas</label>
                        <input type="number" min="0" @bind="_request.HeadCount" class="form-control" placeholder="0" />
                    </div>
                }

                @if (SelectedTemplate.Fields.Contains("weight_per_head"))
                {
                    <div class="form-group">
                        <label>Peso Promedio (kg)</label>
                        <input type="number" step="0.01" min="0" @bind="_weightPerHead" class="form-control" placeholder="0.00" />
                    </div>
                }

                @if (SelectedTemplate.Fields.Contains("field_id"))
                {
                    <div class="form-group">
                        <label>Campo</label>
                        <select @bind="_request.FieldId" class="form-control">
                            <option value="">Seleccione...</option>
                            @if (_fields != null)
                            {
                                @foreach (var f in _fields)
                                {
                                    <option value="@f.Id">@f.Name</option>
                                }
                            }
                        </select>
                    </div>
                }

                @if (SelectedTemplate.Fields.Contains("category_id"))
                {
                    <div class="form-group">
                        <label>Categoria</label>
                        <select @bind="_request.CategoryId" class="form-control">
                            <option value="">Seleccione...</option>
                            @if (_categories != null)
                            {
                                @foreach (var c in _categories)
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            }
                        </select>
                    </div>
                }

                @if (SelectedTemplate.Fields.Contains("activity_id"))
                {
                    <div class="form-group">
                        <label>Actividad</label>
                        <select @bind="_request.ActivityId" class="form-control">
                            <option value="">Seleccione...</option>
                            @if (_activities != null)
                            {
                                @foreach (var a in _activities)
                                {
                                    <option value="@a.Id">@a.Name</option>
                                }
                            }
                        </select>
                    </div>
                }

                @if (SelectedTemplate.Fields.Contains("observations"))
                {
                    <div class="form-group">
                        <label>Observaciones</label>
                        <textarea @bind="_request.Observations" class="form-control" rows="3" placeholder="Detalles adicionales..."></textarea>
                    </div>
                }

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger mt-md">
                        <span class="material-icons" style="font-size:18px;">error</span>
                        @_error
                    </div>
                }
            </div>

            <div class="drawer-footer">
                <button class="btn btn-secondary" @onclick="HandleClose">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleSave" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="spinner"></span>
                        <span>Guardando...</span>
                    }
                    else
                    {
                        <span class="material-icons" style="font-size:18px;">check</span>
                        <span>Registrar Evento</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public EventTemplate? SelectedTemplate { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private RegisterEventRequest _request = new();
    private DateTime _eventDate = DateTime.Today;
    private double _weightPerHead;
    private bool _saving;
    private string _error = "";

    private List<FieldMessage>? _fields;
    private List<AnimalCategoryMessage>? _categories;
    private List<ActivityMessage>? _activities;

    protected override async Task OnParametersSetAsync()
    {
        if (SelectedTemplate != null)
        {
            _error = "";
            _weightPerHead = 0;
            _eventDate = DateTime.Today;
            _request = new RegisterEventRequest
            {
                TemplateId = SelectedTemplate.Id,
                OccurredOn = Timestamp.FromDateTime(DateTime.UtcNow)
            };
            await LoadCatalogs();
        }
    }

    private async Task LoadCatalogs()
    {
        try
        {
            if (string.IsNullOrEmpty(State.ActiveTenantId)) return;
            var f = await CatalogSvc.GetFieldsAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId });
            _fields = f.Data?.Fields.ToList() ?? new();
            var c = await CatalogSvc.GetAnimalCategoriesAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId });
            _categories = c.Data?.Categories.ToList() ?? new();
            var a = await CatalogSvc.GetActivitiesAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId });
            _activities = a.Data?.Activities.ToList() ?? new();
        }
        catch { }
    }

    private async Task HandleSave()
    {
        _saving = true;
        _error = "";
        try
        {
            _request.OccurredOn = Timestamp.FromDateTime(_eventDate.ToUniversalTime());
            _request.WeightPerHead = _weightPerHead.ToString("F2");
            var res = await GrpcClient.RegisterEventAsync(_request);
            if (res.Success)
                await OnSaved.InvokeAsync();
            else
                _error = res.Message;
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }
        finally { _saving = false; }
    }

    private async Task HandleClose() => await OnClose.InvokeAsync();
}
