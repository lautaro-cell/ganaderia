@using GestorGanadero.Services.Common.Contracts
@using GestorGanadero.Services.Catalog.Contracts
@using GestorGanadero.Client.Services
@inject AppStateContainer State
@inject CatalogService.CatalogServiceClient GrpcClient
@inject IJSRuntime JS

<div class="split-view">
    <div class="master-panel">
        <div style="padding:16px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border);">
            <h3 style="font-size:1rem; font-weight:600;">Campos</h3>
            <button class="btn btn-primary btn-sm" @onclick="NewField">
                <span class="material-icons" style="font-size:16px;">add</span> Nuevo
            </button>
        </div>
        <div style="flex:1; overflow-y:auto;">
            @if (_fields == null)
            {
                <div class="loading-container"><div class="spinner"></div></div>
            }
            else
            {
                @foreach (var f in _fields)
                {
                    <div class="master-item @(_selected?.Id == f.Id ? "selected" : "")" @onclick="() => Select(f)">
                        <div>
                            <div style="font-size:0.875rem; font-weight:500;">@f.Name</div>
                            <div style="font-size:0.75rem; color:var(--text-muted);">@f.Description</div>
                        </div>
                        <span class="badge @(f.IsActive ? "badge-success" : "badge-neutral")">@(f.IsActive ? "Activo" : "Inactivo")</span>
                    </div>
                }
            }
        </div>
    </div>

    <div class="detail-panel">
        @if (_selected == null)
        {
            <div class="empty-state">
                <span class="material-icons">terrain</span>
                <p>Selecciona un campo o crea uno nuevo.</p>
            </div>
        }
        else
        {
            <h3 style="margin-bottom:24px;">@(string.IsNullOrEmpty(_selected.Id) ? "Nuevo Campo" : "Editar Campo")</h3>
            <div class="form-group">
                <label>Nombre</label>
                <input type="text" @bind="_selected.Name" class="form-control" placeholder="Ej: La Estancia" />
            </div>
            <div class="form-group">
                <label>Descripción</label>
                <textarea @bind="_selected.Description" class="form-control" rows="3" placeholder="Ubicación, descripción..."></textarea>
            </div>
            <div class="checkbox-group" style="margin-bottom:24px;">
                <input type="checkbox" @bind="_selected.IsActive" id="fieldActive" />
                <label for="fieldActive">Activo</label>
            </div>

            @if (!string.IsNullOrEmpty(_msg))
            {
                <div class="alert @(_ok ? "alert-success" : "alert-danger") mb-md" style="margin-bottom:16px;">@_msg</div>
            }

            <div class="flex gap-sm">
                @if (!string.IsNullOrEmpty(_selected.Id))
                {
                    <button class="btn btn-danger-outline" @onclick="DeleteField">Eliminar</button>
                }
                <div style="flex:1;"></div>
                <button class="btn btn-primary" @onclick="SaveField" disabled="@_saving">
                    @if (_saving) { <span class="spinner"></span> }
                    Guardar
                </button>
            </div>
        }
    </div>
</div>

@code {
    private List<FieldMessage>? _fields;
    private FieldMessage? _selected;
    private bool _saving;
    private string _msg = "";
    private bool _ok;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        if (string.IsNullOrEmpty(State.ActiveTenantId)) return;
        try
        {
            var r = await GrpcClient.GetFieldsAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId });
            _fields = r.Fields.ToList();
        }
        catch { }
    }

    private void NewField() { _selected = new FieldMessage { IsActive = true, TenantId = State.ActiveTenantId }; _msg = ""; }
    private void Select(FieldMessage f) { _selected = new FieldMessage { Id = f.Id, Name = f.Name, Description = f.Description, IsActive = f.IsActive, TenantId = f.TenantId }; _msg = ""; }

    private async Task SaveField()
    {
        if (_selected == null || string.IsNullOrWhiteSpace(_selected.Name)) return;
        _saving = true; _msg = ""; StateHasChanged();
        try
        {
            var r = string.IsNullOrEmpty(_selected.Id) ? await GrpcClient.CreateFieldAsync(_selected) : await GrpcClient.UpdateFieldAsync(_selected);
            if (r.Success) { _ok = true; _msg = "Guardado correctamente."; await Load(); }
            else { _ok = false; _msg = r.Message; }
        }
        catch (Exception ex) { _ok = false; _msg = $"Error: {ex.Message}"; }
        finally { _saving = false; StateHasChanged(); }
    }

    private async Task DeleteField()
    {
        if (_selected == null || string.IsNullOrEmpty(_selected.Id)) return;
        if (!await JS.InvokeAsync<bool>("confirm", $"Eliminar campo '{_selected.Name}'?")) return;
        try
        {
            var r = await GrpcClient.DeleteFieldAsync(new DeleteEntityRequest { Id = _selected.Id, TenantId = State.ActiveTenantId });
            if (r.Success) { _selected = null; await Load(); }
        }
        catch (Exception ex) { _ok = false; _msg = $"Error: {ex.Message}"; }
    }
}
