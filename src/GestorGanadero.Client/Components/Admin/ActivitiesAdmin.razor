@using GestorGanadero.Services.Common.Contracts
@using GestorGanadero.Services.Catalog.Contracts
@using GestorGanadero.Client.Services
@inject AppStateContainer State
@inject CatalogService.CatalogServiceClient GrpcClient
@inject IJSRuntime JS

<div class="flex flex-col gap-6">
    <!-- Breadcrumbs -->
    <div class="flex items-center gap-2 text-[11px] font-medium text-text-secondary uppercase tracking-widest opacity-60">
        <a href="/" class="hover:text-white transition-colors no-underline">Inicio</a>
        <span class="material-symbols-outlined text-[14px]">chevron_right</span>
        <span class="cursor-default">Administración</span>
        <span class="material-symbols-outlined text-[14px]">chevron_right</span>
        <span class="text-primary font-bold">Actividades</span>
    </div>

    <!-- Header Section -->
    <div class="flex flex-col gap-1">
        <h2 class="text-white text-2xl font-bold tracking-tight flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">work</span>
            Gestión de Actividades
        </h2>
        <p class="text-text-secondary text-sm">Tipos de actividad productiva (Cría, Recría, Feedlot, etc.)</p>
    </div>

    <!-- Activities Table -->
    <div class="overflow-hidden rounded-xl border border-border-dark bg-surface-dark shadow-xl">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-darker/50 border-b border-border-dark">
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-text-secondary">Nombre</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-text-secondary">Descripción</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-text-secondary text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border-dark/30">
                    @if (_items == null)
                    {
                        <tr>
                            <td colspan="3" class="px-6 py-10 text-center">
                                <div class="flex flex-col items-center gap-3">
                                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
                                    <p class="text-text-secondary text-sm font-medium">Cargando actividades...</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else if (!_items.Any())
                    {
                        <tr>
                            <td colspan="3" class="px-6 py-10 text-center text-text-disabled">
                                No hay actividades registradas.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var a in _items)
                        {
                            <tr class="hover:bg-white/5 transition-colors group">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-2">
                                        <span class="text-white font-bold text-sm uppercase">@a.Name</span>
                                        @if (a.IsGlobal)
                                        {
                                            <span class="text-[9px] px-1.5 py-0.5 rounded bg-blue-500/10 text-blue-400 border border-blue-500/20 font-black tracking-tighter">GLOBAL</span>
                                        }
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-text-secondary text-sm">-</span>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <button class="flex items-center gap-1 px-3 py-1.5 rounded-lg bg-surface-darker border border-border-dark text-text-secondary hover:text-white hover:border-text-secondary transition-all text-xs font-bold" @onclick="() => Edit(a)">
                                            <span class="material-symbols-outlined text-sm">edit</span>
                                            Editar
                                        </button>
                                        @if (!a.IsGlobal)
                                        {
                                            <button class="flex items-center gap-1 px-3 py-1.5 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 hover:bg-red-500/20 transition-all text-xs font-bold" @onclick="() => Delete(a)">
                                                <span class="material-symbols-outlined text-sm">delete</span>
                                                Eliminar
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Create/Edit Form Section -->
    <div class="mt-4 flex flex-col gap-4">
        <h3 class="text-white text-lg font-bold flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">@(string.IsNullOrEmpty(_model.Id) ? "add_circle" : "edit_square")</span>
            @(string.IsNullOrEmpty(_model.Id) ? "Crear Actividad" : "Editar Actividad")
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="flex flex-col gap-2">
                <input type="text" @bind="_model.Name" class="w-full bg-surface-darker border border-border-dark rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-primary transition-colors" 
                       placeholder="Nombre (ej: CRIA, RECRIA)" />
            </div>
            <div class="flex flex-col gap-2">
                <input type="text" class="w-full bg-surface-darker border border-border-dark rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-primary transition-colors opacity-50 cursor-not-allowed" 
                       placeholder="Descripción" disabled />
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_msg))
        {
            <div class="flex items-center gap-2 p-3 rounded-lg @(_ok ? "bg-green-500/10 text-green-400 border border-green-500/20" : "bg-red-500/10 text-red-400 border border-red-500/20") text-sm">
                <span class="material-symbols-outlined text-lg">@(_ok ? "check_circle" : "error")</span>
                <span>@_msg</span>
            </div>
        }

        <button class="flex items-center justify-center gap-2 w-full h-12 bg-primary hover:bg-red-700 transition-colors text-white font-bold rounded-xl shadow-lg shadow-primary/20 disabled:opacity-50" 
                @onclick="Save" disabled="@_saving">
            @if (_saving)
            {
                <div class="animate-spin rounded-full h-5 w-5 border-b-2 border-white"></div>
            }
            else
            {
                <span class="material-symbols-outlined">save</span>
            }
            <span>@(string.IsNullOrEmpty(_model.Id) ? "Crear" : "Guardar Cambios")</span>
        </button>
        
        @if (!string.IsNullOrEmpty(_model.Id))
        {
            <button class="text-text-secondary hover:text-white text-xs font-bold uppercase tracking-widest transition-colors mt-1" @onclick="CancelEdit">
                Cancelar Edición
            </button>
        }
    </div>
</div>

@code {
    private List<ActivityMessage>? _items;
    private ActivityMessage _model = new() { IsGlobal = false };
    private bool _saving;
    private string _msg = "";
    private bool _ok;

    protected override async Task OnInitializedAsync()
    {
        _model.TenantId = State.ActiveTenantId;
        await Load();
    }

    private async Task Load()
    {
        if (string.IsNullOrEmpty(State.ActiveTenantId)) return;
        try
        {
            var r = await GrpcClient.GetActivitiesAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId });
            _items = r.Activities.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading activities: {ex.Message}");
        }
    }

    private void Edit(ActivityMessage a)
    {
        _model = new ActivityMessage { 
            Id = a.Id, 
            Name = a.Name, 
            IsGlobal = a.IsGlobal, 
            TenantId = a.TenantId 
        };
        _msg = "";
    }

    private void CancelEdit()
    {
        _model = new ActivityMessage { IsGlobal = false, TenantId = State.ActiveTenantId };
        _msg = "";
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_model.Name))
        {
            _ok = false;
            _msg = "El nombre es obligatorio.";
            return;
        }

        _saving = true;
        _msg = "";
        StateHasChanged();

        try
        {
            var r = string.IsNullOrEmpty(_model.Id) 
                ? await GrpcClient.CreateActivityAsync(_model) 
                : await GrpcClient.UpdateActivityAsync(_model);

            if (r.Success)
            {
                _ok = true;
                _msg = string.IsNullOrEmpty(_model.Id) ? "Actividad creada correctamente." : "Actividad actualizada correctamente.";
                CancelEdit();
                await Load();
            }
            else
            {
                _ok = false;
                _msg = r.Message;
            }
        }
        catch (Exception ex)
        {
            _ok = false;
            _msg = $"Error: {ex.Message}";
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task Delete(ActivityMessage a)
    {
        if (a.IsGlobal) return;
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Está seguro que desea eliminar la actividad '{a.Name}'?")) return;
        try
        {
            var r = await GrpcClient.DeleteActivityAsync(new DeleteEntityRequest { Id = a.Id, TenantId = State.ActiveTenantId });
            if (r.Success)
            {
                if (_model.Id == a.Id) CancelEdit();
                await Load();
            }
        }
        catch (Exception ex)
        {
            _ok = false;
            _msg = $"Error al eliminar: {ex.Message}";
        }
    }
}
