@using GestorGanadero.Services.Common.Contracts
@using GestorGanadero.Services.Identity.Contracts
@using GestorGanadero.Services.Catalog.Contracts
@using GestorGanadero.Services.Operations.Contracts
@using GestorGanadero.Services.Reporting.Contracts
@using GestorGanadero.Services.Sync.Contracts
@using GestorGanadero.Client.Services
@inject AppStateContainer State
@inject CatalogService.CatalogServiceClient GrpcClient
@inject IJSRuntime JS

<div class="split-view">
    <div class="master-list">
        <div class="list-header">
            <h3>Actividades</h3>
            <button class="btn-icon-add" @onclick="NewActivity">
                <span class="material-icons">add</span>
            </button>
        </div>
        
        <div class="list-items">
            @if (activities == null)
            {
                <div class="spinner-sm"></div>
            }
            else if (!activities.Any())
            {
                <p class="empty-msg">No hay actividades.</p>
            }
            else
            {
                @foreach (var activity in activities)
                {
                    <div class="list-row @(selectedActivity?.Id == activity.Id ? "selected" : "")" 
                         @onclick="() => SelectActivity(activity)">
                        <div class="row-info">
                            <span class="name">@activity.Name</span>
                            @if (activity.IsGlobal)
                            {
                                <span class="badge-global">Global</span>
                            }
                        </div>
                        <span class="material-icons">chevron_right</span>
                    </div>
                }
            }
        </div>
    </div>

    <div class="detail-form">
        @if (selectedActivity == null)
        {
            <div class="empty-state">
                <span class="material-icons">assignment</span>
                <p>Seleccione una actividad para editar.</p>
            </div>
        }
        else
        {
            <div class="form-scroll">
                <h4>@(string.IsNullOrEmpty(selectedActivity.Id) ? "Nueva Actividad" : "Editar Actividad")</h4>
                
                <div class="form-group">
                    <label>Nombre</label>
                    <input type="text" @bind="selectedActivity.Name" placeholder="Ej: Cría, Invernada..." />
                </div>

                <div class="form-group row-toggle">
                    <label>Actividad Global</label>
                    <input type="checkbox" @bind="selectedActivity.IsGlobal" class="toggle-input" />
                </div>

                <div class="form-actions">
                    @if (!string.IsNullOrEmpty(selectedActivity.Id) && !selectedActivity.IsGlobal)
                    {
                        <button class="btn-danger-outline" @onclick="DeleteActivity">Eliminar</button>
                    }
                    <div class="spacer"></div>
                    <button class="btn-primary" @onclick="SaveActivity" disabled="@isSaving">
                        @if (isSaving) { <span class="spinner-inline"></span> }
                        Guardar
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(message))
                {
                    <p class="form-message @(success ? "success" : "error")">@message</p>
                }
            </div>
        }
    </div>
</div>

<style>
    .split-view { display: flex; height: 100%; }
    .master-list { width: 320px; border-right: 1px solid var(--border); display: flex; flex-direction: column; }
    .detail-form { flex: 1; background: var(--surface); padding: 24px; }
    
    .list-header { padding: 16px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); }
    .list-items { flex: 1; overflow-y: auto; }
    
    .list-row { padding: 12px 16px; border-bottom: 1px solid var(--border); cursor: pointer; display: flex; justify-content: space-between; align-items: center; transition: background 0.2s; }
    .list-row:hover { background: var(--surface-2); }
    .list-row.selected { background: rgba(230, 0, 0, 0.05); border-left: 3px solid var(--accent); }
    
    .badge-global { font-size: 0.6rem; background: var(--surface-2); color: var(--text-secondary); padding: 2px 6px; border-radius: 4px; border: 1px solid var(--border); }

    .form-group { margin-bottom: 20px; display: flex; flex-direction: column; gap: 8px; }
    .form-group label { font-size: 0.75rem; color: var(--text-secondary); text-transform: uppercase; font-weight: 600; }
    .form-group input { background: var(--surface-2); border: 1px solid var(--border); color: var(--text-primary); padding: 10px; border-radius: 6px; }
    
    .row-toggle { flex-direction: row; align-items: center; justify-content: space-between; }
    .form-actions { margin-top: 32px; display: flex; gap: 12px; }
    .spacer { flex: 1; }
    
    .empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; color: var(--text-secondary); opacity: 0.5; }
    .empty-state .material-icons { font-size: 64px; margin-bottom: 16px; }

    .btn-icon-add { background: var(--accent); color: white; border: none; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
    .btn-danger-outline { background: transparent; border: 1px solid var(--accent); color: var(--accent); padding: 8px 16px; border-radius: 6px; }
    
    .form-message { margin-top: 16px; font-size: 0.85rem; font-weight: 600; }
    .form-message.success { color: #00ff00; }
    .form-message.error { color: var(--accent); }

    .spinner-inline { width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff; border-radius: 50%; animation: spin 0.8s linear infinite; display: inline-block; margin-right: 8px; }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@code {
    private List<ActivityMessage>? activities;
    private ActivityMessage? selectedActivity;
    private bool isSaving = false;
    private string message = "";
    private bool success = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadActivities();
    }

    private async Task LoadActivities()
    {
        try
        {
            var response = await GrpcClient.GetActivitiesAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId });
            activities = response.Activities.ToList();
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private void NewActivity()
    {
        selectedActivity = new ActivityMessage { TenantId = State.ActiveTenantId };
        message = "";
    }

    private void SelectActivity(ActivityMessage activity)
    {
        selectedActivity = new ActivityMessage
        {
            Id = activity.Id,
            Name = activity.Name,
            IsGlobal = activity.IsGlobal,
            TenantId = activity.TenantId
        };
        message = "";
    }

    private async Task SaveActivity()
    {
        if (selectedActivity == null || string.IsNullOrWhiteSpace(selectedActivity.Name)) return;

        isSaving = true;
        message = "";
        StateHasChanged();

        try
        {
            ActionResponse response;
            if (string.IsNullOrEmpty(selectedActivity.Id))
                response = await GrpcClient.CreateActivityAsync(selectedActivity);
            else
                response = await GrpcClient.UpdateActivityAsync(selectedActivity);

            if (response.Success)
            {
                success = true;
                message = "Guardado con éxito.";
                await LoadActivities();
                selectedActivity = activities?.FirstOrDefault(a => a.Id == (string.IsNullOrEmpty(selectedActivity.Id) ? response.ObjectId : selectedActivity.Id));
            }
            else
            {
                success = false;
                message = response.Message;
            }
        }
        catch (Exception ex)
        {
            success = false;
            message = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task DeleteActivity()
    {
        if (selectedActivity == null || string.IsNullOrEmpty(selectedActivity.Id)) return;

        var confirmed = await JS.InvokeAsync<bool>("confirm", "¿Eliminar actividad?");
        if (!confirmed) return;

        try
        {
            var response = await GrpcClient.DeleteActivityAsync(new DeleteEntityRequest { Id = selectedActivity.Id, TenantId = State.ActiveTenantId });
            if (response.Success)
            {
                selectedActivity = null;
                await LoadActivities();
            }
            else
            {
                success = false;
                message = response.Message;
            }
        }
        catch (Exception ex)
        {
            success = false;
            message = $"Error: {ex.Message}";
        }
    }
}

