@using GestorGanadero.Services.Common.Contracts
@using GestorGanadero.Services.Catalog.Contracts
@using GestorGanadero.Client.Services
@inject AppStateContainer State
@inject CatalogService.CatalogServiceClient GrpcClient
@inject IJSRuntime JS

<div class="split-view">
    <div class="master-panel">
        <div style="padding:16px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border);">
            <h3 style="font-size:1rem; font-weight:600;">Categorías</h3>
            <button class="btn btn-primary btn-sm" @onclick="New"><span class="material-icons" style="font-size:16px;">add</span> Nueva</button>
        </div>
        <div style="flex:1; overflow-y:auto;">
            @if (_items == null) { <div class="loading-container"><div class="spinner"></div></div> }
            else { @foreach (var c in _items) {
                <div class="master-item @(_sel?.Id == c.Id ? "selected" : "")" @onclick="() => Sel(c)">
                    <div><div style="font-size:0.875rem; font-weight:500;">@c.Name</div><div style="font-size:0.75rem; color:var(--text-muted);">@c.StandardWeightKg kg</div></div>
                </div>
            }}
        </div>
    </div>
    <div class="detail-panel">
        @if (_sel == null) { <div class="empty-state"><span class="material-icons">category</span><p>Selecciona o crea una categoría.</p></div> }
        else {
            <h3 style="margin-bottom:24px;">@(string.IsNullOrEmpty(_sel.Id) ? "Nueva" : "Editar") Categoría</h3>
            <div class="form-group"><label>Nombre</label><input type="text" @bind="_sel.Name" class="form-control" /></div>
            <div class="form-group"><label>Actividad</label>
                <select @bind="_sel.ActivityId" class="form-control"><option value="">Seleccione...</option>@if(_acts!=null){@foreach(var a in _acts){<option value="@a.Id">@a.Name</option>}}</select>
            </div>
            <div class="form-group"><label>Peso Estándar (KG)</label><input type="text" @bind="_sel.StandardWeightKg" class="form-control" /></div>
            <div class="form-group"><label>Tipo</label><input type="text" @bind="_sel.CategoryType" class="form-control" placeholder="Macho/Hembra..." /></div>
            <div class="checkbox-group" style="margin-bottom:24px;"><input type="checkbox" @bind="_sel.IsActive" id="catAct" /><label for="catAct">Activo</label></div>
            @if (!string.IsNullOrEmpty(_msg)) { <div class="alert @(_ok?"alert-success":"alert-danger") mb-md" style="margin-bottom:16px;">@_msg</div> }
            <div class="flex gap-sm">
                @if (!string.IsNullOrEmpty(_sel.Id)) { <button class="btn btn-danger-outline" @onclick="Del">Eliminar</button> }
                <div style="flex:1;"></div>
                <button class="btn btn-primary" @onclick="Save" disabled="@_saving">@if(_saving){<span class="spinner"></span>} Guardar</button>
            </div>
        }
    </div>
</div>

@code {
    private List<AnimalCategoryMessage>? _items;
    private List<ActivityMessage>? _acts;
    private AnimalCategoryMessage? _sel;
    private bool _saving; private string _msg = ""; private bool _ok;

    protected override async Task OnInitializedAsync() => await Load();
    private async Task Load() {
        if (string.IsNullOrEmpty(State.ActiveTenantId)) return;
        try { var r = await GrpcClient.GetAnimalCategoriesAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId }); _items = r.Categories.ToList(); var a = await GrpcClient.GetActivitiesAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId }); _acts = a.Activities.ToList(); } catch { }
    }
    private void New() { _sel = new AnimalCategoryMessage { IsActive = true, TenantId = State.ActiveTenantId }; _msg = ""; }
    private void Sel(AnimalCategoryMessage c) { _sel = new AnimalCategoryMessage { Id = c.Id, Name = c.Name, ActivityId = c.ActivityId, StandardWeightKg = c.StandardWeightKg, CategoryType = c.CategoryType, IsActive = c.IsActive, TenantId = c.TenantId }; _msg = ""; }
    private async Task Save() {
        if (_sel == null || string.IsNullOrWhiteSpace(_sel.Name)) return;
        _saving = true; _msg = ""; StateHasChanged();
        try { var r = string.IsNullOrEmpty(_sel.Id) ? await GrpcClient.CreateAnimalCategoryAsync(_sel) : await GrpcClient.UpdateAnimalCategoryAsync(_sel); if (r.Success) { _ok = true; _msg = "Guardado."; await Load(); } else { _ok = false; _msg = r.Message; } }
        catch (Exception ex) { _ok = false; _msg = $"Error: {ex.Message}"; }
        finally { _saving = false; StateHasChanged(); }
    }
    private async Task Del() {
        if (_sel == null || string.IsNullOrEmpty(_sel.Id)) return;
        if (!await JS.InvokeAsync<bool>("confirm", $"Eliminar '{_sel.Name}'?")) return;
        try { var r = await GrpcClient.DeleteAnimalCategoryAsync(new DeleteEntityRequest { Id = _sel.Id, TenantId = State.ActiveTenantId }); if (r.Success) { _sel = null; await Load(); } } catch (Exception ex) { _ok = false; _msg = $"Error: {ex.Message}"; }
    }
}
