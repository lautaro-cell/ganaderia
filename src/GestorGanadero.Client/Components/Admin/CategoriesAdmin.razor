@using GestorGanadero.Services.Catalog.Contracts
@using GestorGanadero.Services.Sync.Contracts
@using GestorGanadero.Services.Common.Contracts
@using GestorGanadero.Client.Services
@inject AppStateContainer State
@inject CatalogService.CatalogServiceClient CatalogClient
@inject SyncService.SyncServiceClient SyncClient
@inject IJSRuntime JS

<div class="flex flex-col gap-6">
    <!-- Breadcrumbs -->
    <div class="flex items-center gap-2 text-[11px] font-medium text-text-secondary uppercase tracking-widest opacity-60">
        <a href="/" class="hover:text-white transition-colors no-underline">Inicio</a>
        <span class="material-symbols-outlined text-[14px]">chevron_right</span>
        <span class="cursor-default">Administración</span>
        <span class="material-symbols-outlined text-[14px]">chevron_right</span>
        <span class="text-primary font-bold">Categorías</span>
    </div>

    <!-- Header -->
    <div class="flex flex-wrap justify-between items-center gap-4">
        <div class="flex flex-col gap-1">
            <h2 class="text-white text-2xl font-bold tracking-tight flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">pets</span>
                Categorías de Hacienda (GestorMax)
            </h2>
            <p class="text-text-secondary text-sm">Conceptos de hacienda sincronizados directamente desde el ERP.</p>
        </div>
        <button class="flex min-w-[200px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 px-5 bg-primary hover:bg-red-700 transition-colors text-white text-sm font-bold leading-normal tracking-tight shadow-lg shadow-primary/20 disabled:opacity-50" 
                @onclick="Sync" disabled="@_syncing">
            <span class="material-symbols-outlined mr-2 @(_syncing ? "animate-spin" : "")">sync</span>
            <span>@(_syncing ? "Sincronizando..." : "Sincronizar Ahora")</span>
        </button>
    </div>

    <!-- ERP Concepts Table -->
    <div class="bg-background-main border border-border-dark rounded-2xl overflow-hidden shadow-xl shadow-black/20">
        <table class="w-full text-left text-sm border-collapse">
            <thead class="bg-surface-darker text-text-secondary uppercase text-[10px] tracking-widest border-b border-border-dark">
                <tr>
                    <th class="px-6 py-4">Descripción</th>
                    <th class="px-6 py-4">Subgrupo</th>
                    <th class="px-6 py-4 text-center">Stock ERP</th>
                    <th class="px-6 py-4 text-center">Unidad</th>
                    <th class="px-6 py-4 text-right">Cod. ERP</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border-dark/30">
                @if (_erpConcepts == null)
                {
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center">
                            <div class="flex flex-col items-center gap-3">
                                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
                                <p class="text-text-secondary text-sm font-medium">Cargando categorías...</p>
                            </div>
                        </td>
                    </tr>
                }
                else if (!_erpConcepts.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center">
                            <div class="flex flex-col items-center gap-2 opacity-40">
                                <span class="material-symbols-outlined text-5xl">sync_problem</span>
                                <p class="text-text-secondary font-bold">No hay categorías sincronizadas</p>
                                <p class="text-text-disabled text-xs">Pulse el botón superior para traer datos de GestorMax.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var c in _erpConcepts)
                    {
                        <tr class="hover:bg-white/5 transition-colors group">
                            <td class="px-6 py-4">
                                <span class="text-white font-bold text-sm uppercase">@c.Description</span>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-text-secondary text-xs bg-surface-darker px-2 py-0.5 rounded border border-border-dark/50">@c.Subgrupo</span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="text-primary font-bold">@c.Stock.ToString("N0")</span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="text-text-secondary text-xs">@c.UnitA</span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <span class="font-mono text-[10px] text-text-disabled">#@c.ExternalId</span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (!string.IsNullOrEmpty(_msg))
    {
        <div class="flex items-center gap-3 p-4 rounded-xl @(_ok ? "bg-green-500/10 text-green-400 border border-green-500/20" : "bg-red-500/10 text-red-400 border border-red-500/20") text-sm animate-in fade-in duration-300">
            <span class="material-symbols-outlined text-lg">@(_ok ? "check_circle" : "error")</span>
            <span class="font-medium">@_msg</span>
        </div>
    }

    <!-- Manual Section (Hidden by default or minimized) -->
    <div class="mt-8 pt-8 border-t border-border-dark/30">
        <details class="group">
            <summary class="flex items-center gap-2 text-text-disabled hover:text-text-secondary transition-colors cursor-pointer list-none">
                <span class="material-symbols-outlined transition-transform group-open:rotate-90">chevron_right</span>
                <span class="text-xs font-bold uppercase tracking-widest">Configuración Manual (Avanzado)</span>
            </summary>
            <div class="mt-6 flex flex-col gap-6">
                <p class="text-text-disabled text-xs px-6 italic">Utilice esta sección solo si necesita crear categorías locales que no existen en el ERP.</p>
                <div class="bg-background-main rounded-2xl border border-border-dark p-6">
                    <h3 class="text-white font-bold flex items-center gap-2 mb-6">
                        <span class="material-symbols-outlined text-primary">add_circle</span> Crear Categoría Local
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
                        <label class="flex flex-col gap-2">
                            <span class="text-white text-sm font-medium">Nombre</span>
                            <input type="text" @bind="_newCat.Name" class="w-full bg-[#271c1c] border-[#543b3b] rounded-xl px-4 py-3 text-sm text-white focus:ring-primary outline-none" placeholder="Nombre" />
                        </label>
                        <label class="flex flex-col gap-2">
                            <span class="text-white text-sm font-medium">Actividad</span>
                            <select @bind="_newCat.ActivityId" class="w-full bg-[#271c1c] border-[#543b3b] rounded-xl px-4 py-3 text-sm text-white focus:ring-primary outline-none cursor-pointer">
                                <option value="">Seleccionar actividad...</option>
                                @if (_activities != null) { @foreach (var a in _activities) { <option value="@a.Id">@a.Name</option> } }
                            </select>
                        </label>
                        <label class="flex flex-col gap-2">
                            <span class="text-white text-sm font-medium">Peso estándar (Kg)</span>
                            <input type="number" @bind="_newCat.StandardWeightKg" class="w-full bg-[#271c1c] border-[#543b3b] rounded-xl px-4 py-3 text-sm text-white focus:ring-primary outline-none" placeholder="0" />
                        </label>
                        <button class="md:col-span-3 w-full bg-surface-dark border border-border-dark hover:border-primary text-white font-bold py-3 rounded-xl transition-all flex items-center justify-center gap-2" @onclick="SaveLocal">
                            <span class="material-symbols-outlined text-[20px]">add</span> Crear Local
                        </button>
                    </div>
                </div>
            </div>
        </details>
    </div>
</div>

@code {
    private List<ErpConceptMessage>? _erpConcepts;
    private List<ActivityMessage>? _activities;
    private AnimalCategoryMessage _newCat = new() { IsActive = true };
    private bool _syncing;
    private string _msg = "";
    private bool _ok;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load() {
        if (string.IsNullOrEmpty(State.ActiveTenantId)) return;
        try 
        {
            var r = await CatalogClient.GetErpConceptsAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId });
            _erpConcepts = r.Concepts.ToList();
            
            var a = await CatalogClient.GetActivitiesAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId });
            _activities = a.Activities.ToList();
            
            _newCat.TenantId = State.ActiveTenantId;
        }
        catch (Exception ex)
        {
            _msg = $"Error al cargar datos: {ex.Message}";
            _ok = false;
        }
    }

    private async Task Sync() {
        if (_syncing) return;
        _syncing = true;
        _msg = "Iniciando sincronización con GestorMax...";
        _ok = true;
        StateHasChanged();

        try {
            var res = await SyncClient.SyncCatalogAsync(new SyncCatalogRequest { TenantId = State.ActiveTenantId });
            if (res.Success) {
                _msg = "Sincronización completada exitosamente.";
                _ok = true;
                await Load();
            } else {
                _msg = res.Message;
                _ok = false;
            }
        } catch (Exception ex) {
            _msg = $"Error de red: {ex.Message}";
            _ok = false;
        } finally {
            _syncing = false;
            StateHasChanged();
        }
    }

    private async Task SaveLocal() {
        if (string.IsNullOrWhiteSpace(_newCat.Name)) return;
        await CatalogClient.CreateAnimalCategoryAsync(_newCat);
        _newCat = new AnimalCategoryMessage { IsActive = true, TenantId = State.ActiveTenantId };
        _msg = "Categoría local creada.";
        _ok = true;
        await Load();
    }
}
