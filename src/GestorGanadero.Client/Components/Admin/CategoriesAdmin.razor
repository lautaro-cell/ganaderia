@using GestorGanadero.Services.Common.Contracts
@using GestorGanadero.Services.Identity.Contracts
@using GestorGanadero.Services.Catalog.Contracts
@using GestorGanadero.Services.Operations.Contracts
@using GestorGanadero.Services.Reporting.Contracts
@using GestorGanadero.Services.Sync.Contracts
@using GestorGanadero.Client.Services
@inject AppStateContainer State
@inject CatalogService.CatalogServiceClient GrpcClient
@inject IJSRuntime JS

<div class="split-view">
    <div class="master-list">
        <div class="list-header">
            <h3>Categorías</h3>
            <button class="btn-icon-add" @onclick="NewCategory">
                <span class="material-icons">add</span>
            </button>
        </div>
        
        <div class="list-items">
            @if (categories == null)
            {
                <div class="spinner-sm"></div>
            }
            else if (!categories.Any())
            {
                <p class="empty-msg">No hay categorías.</p>
            }
            else
            {
                @foreach (var cat in categories)
                {
                    <div class="list-row @(selectedCategory?.Id == cat.Id ? "selected" : "")" 
                         @onclick="() => SelectCategory(cat)">
                        <div class="row-info">
                            <span class="name">@cat.Name</span>
                            <span class="sub-name">@cat.StandardWeightKg kg</span>
                        </div>
                        <span class="material-icons">chevron_right</span>
                    </div>
                }
            }
        </div>
    </div>

    <div class="detail-form">
        @if (selectedCategory == null)
        {
            <div class="empty-state">
                <span class="material-icons">category</span>
                <p>Seleccione una categoría para editar.</p>
            </div>
        }
        else
        {
            <div class="form-scroll">
                <h4>@(string.IsNullOrEmpty(selectedCategory.Id) ? "Nueva Categoría" : "Editar Categoría")</h4>
                
                <div class="form-group">
                    <label>Nombre de Categoría</label>
                    <input type="text" @bind="selectedCategory.Name" placeholder="Ej: Ternero, Vaca..." />
                </div>

                <div class="form-group">
                    <label>Actividad Relacionada</label>
                    <select @bind="selectedCategory.ActivityId">
                        <option value="">Seleccione actividad...</option>
                        @if (activities != null)
                        {
                            @foreach (var act in activities)
                            {
                                <option value="@act.Id">@act.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label>Peso Estándar (KG)</label>
                    <input type="text" @bind="selectedCategory.StandardWeightKg" placeholder="0.00" />
                </div>
                
                <div class="form-group">
                    <label>Tipo de Categoría</label>
                    <input type="text" @bind="selectedCategory.CategoryType" placeholder="Macho/Hembra..." />
                </div>

                <div class="form-group row-toggle">
                    <label>Estado Activo</label>
                    <input type="checkbox" @bind="selectedCategory.IsActive" class="toggle-input" />
                </div>

                <div class="form-actions">
                    @if (!string.IsNullOrEmpty(selectedCategory.Id))
                    {
                        <button class="btn-danger-outline" @onclick="DeleteCategory">Eliminar</button>
                    }
                    <div class="spacer"></div>
                    <button class="btn-primary" @onclick="SaveCategory" disabled="@isSaving">
                        @if (isSaving) { <span class="spinner-inline"></span> }
                        Guardar
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(message))
                {
                    <p class="form-message @(success ? "success" : "error")">@message</p>
                }
            </div>
        }
    </div>
</div>

<style>
    .split-view { display: flex; height: 100%; }
    .master-list { width: 320px; border-right: 1px solid var(--border); display: flex; flex-direction: column; }
    .detail-form { flex: 1; background: var(--surface); padding: 24px; }
    
    .list-header { padding: 16px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); }
    .list-items { flex: 1; overflow-y: auto; }
    
    .list-row { padding: 12px 16px; border-bottom: 1px solid var(--border); cursor: pointer; display: flex; flex-direction: column; gap: 4px; transition: background 0.2s; }
    .list-row:hover { background: var(--surface-2); }
    .list-row.selected { background: rgba(230, 0, 0, 0.05); border-left: 3px solid var(--accent); }
    
    .sub-name { font-size: 0.7rem; color: var(--text-secondary); }

    .form-group { margin-bottom: 20px; display: flex; flex-direction: column; gap: 8px; }
    .form-group label { font-size: 0.75rem; color: var(--text-secondary); text-transform: uppercase; font-weight: 600; }
    .form-group input, .form-group select { background: var(--surface-2); border: 1px solid var(--border); color: var(--text-primary); padding: 10px; border-radius: 6px; }
    
    .row-toggle { flex-direction: row; align-items: center; justify-content: space-between; }
    .form-actions { margin-top: 32px; display: flex; gap: 12px; }
    .spacer { flex: 1; }
    
    .empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; color: var(--text-secondary); opacity: 0.5; }
    .empty-state .material-icons { font-size: 64px; margin-bottom: 16px; }

    .btn-icon-add { background: var(--accent); color: white; border: none; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
    .btn-danger-outline { background: transparent; border: 1px solid var(--accent); color: var(--accent); padding: 8px 16px; border-radius: 6px; }
    
    .form-message { margin-top: 16px; font-size: 0.85rem; font-weight: 600; }
    .form-message.success { color: #00ff00; }
    .form-message.error { color: var(--accent); }

    .spinner-inline { width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff; border-radius: 50%; animation: spin 0.8s linear infinite; display: inline-block; margin-right: 8px; }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@code {
    private List<AnimalCategoryMessage>? categories;
    private List<ActivityMessage>? activities;
    private AnimalCategoryMessage? selectedCategory;
    private bool isSaving = false;
    private string message = "";
    private bool success = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            var catResp = await GrpcClient.GetAnimalCategoriesAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId });
            categories = catResp.Categories.ToList();

            var actResp = await GrpcClient.GetActivitiesAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId });
            activities = actResp.Activities.ToList();
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private void NewCategory()
    {
        selectedCategory = new AnimalCategoryMessage { IsActive = true, TenantId = State.ActiveTenantId };
        message = "";
    }

    private void SelectCategory(AnimalCategoryMessage cat)
    {
        selectedCategory = new AnimalCategoryMessage
        {
            Id = cat.Id,
            Name = cat.Name,
            ActivityId = cat.ActivityId,
            StandardWeightKg = cat.StandardWeightKg,
            CategoryType = cat.CategoryType,
            IsActive = cat.IsActive,
            TenantId = cat.TenantId
        };
        message = "";
    }

    private async Task SaveCategory()
    {
        if (selectedCategory == null || string.IsNullOrWhiteSpace(selectedCategory.Name)) return;

        isSaving = true;
        message = "";
        StateHasChanged();

        try
        {
            ActionResponse response;
            if (string.IsNullOrEmpty(selectedCategory.Id))
                response = await GrpcClient.CreateAnimalCategoryAsync(selectedCategory);
            else
                response = await GrpcClient.UpdateAnimalCategoryAsync(selectedCategory);

            if (response.Success)
            {
                success = true;
                message = "Guardado con éxito.";
                await LoadData();
                selectedCategory = categories?.FirstOrDefault(c => c.Id == (string.IsNullOrEmpty(selectedCategory.Id) ? response.ObjectId : selectedCategory.Id));
            }
            else
            {
                success = false;
                message = response.Message;
            }
        }
        catch (Exception ex)
        {
            success = false;
            message = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task DeleteCategory()
    {
        if (selectedCategory == null || string.IsNullOrEmpty(selectedCategory.Id)) return;

        var confirmed = await JS.InvokeAsync<bool>("confirm", "¿Eliminar categoría?");
        if (!confirmed) return;

        try
        {
            var response = await GrpcClient.DeleteAnimalCategoryAsync(new DeleteEntityRequest { Id = selectedCategory.Id, TenantId = State.ActiveTenantId });
            if (response.Success)
            {
                selectedCategory = null;
                await LoadData();
            }
            else
            {
                success = false;
                message = response.Message;
            }
        }
        catch (Exception ex)
        {
            success = false;
            message = $"Error: {ex.Message}";
        }
    }
}

