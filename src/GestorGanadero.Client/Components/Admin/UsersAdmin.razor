@using GestorGanadero.Services.Common.Contracts
@using GestorGanadero.Services.Identity.Contracts
@using GestorGanadero.Client.Services
@using Google.Protobuf.WellKnownTypes
@inject AppStateContainer State
@inject IdentityService.IdentityServiceClient GrpcClient
@inject IJSRuntime JS

<div style="padding:0;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
        <h3>Gestión de Usuarios</h3>
        <button class="btn btn-primary btn-sm" @onclick="OpenInvite">
            <span class="material-icons" style="font-size:16px;">person_add</span> Invitar Usuario
        </button>
    </div>

    @if (_users == null)
    {
        <div class="loading-container"><div class="spinner spinner-lg"></div></div>
    }
    else if (!_users.Any())
    {
        <div class="empty-state"><span class="material-icons">people</span><p>No hay usuarios registrados.</p></div>
    }
    else
    {
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Email</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in _users)
                    {
                        <tr>
                            <td style="font-weight:500;">@u.Name</td>
                            <td style="color:var(--text-secondary);">@u.Email</td>
                            <td><span class="badge badge-info">@u.RoleName</span></td>
                            <td><span class="badge @(u.IsActive ? "badge-success" : "badge-neutral")">@(u.IsActive ? "Activo" : "Inactivo")</span></td>
                            <td class="text-center">
                                <button class="btn-icon" title="Editar" @onclick="() => Edit(u)"><span class="material-icons">edit</span></button>
                                <button class="btn-icon" title="Eliminar" @onclick="() => Delete(u)"><span class="material-icons">delete_outline</span></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (_showModal)
{
    <div class="modal-backdrop" @onclick="() => _showModal = false">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>@(_editing ? "Editar Usuario" : "Invitar Usuario")</h3>
                <button class="btn-icon" @onclick="() => _showModal = false"><span class="material-icons">close</span></button>
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" @bind="_model.Email" class="form-control" disabled="@_editing" />
            </div>
            <div class="form-group">
                <label>Nombre</label>
                <input type="text" @bind="_model.Name" class="form-control" />
            </div>
            <div class="form-group">
                <label>Rol</label>
                <select @bind="_model.RoleName" class="form-control">
                    <option value="Visor">Visor</option>
                    <option value="Operador">Operador</option>
                    <option value="Admin">Administrador</option>
                </select>
            </div>
            @if (_editing)
            {
                <div class="checkbox-group"><input type="checkbox" @bind="_model.IsActive" id="usrAct" /><label for="usrAct">Usuario Activo</label></div>
            }
            <div class="modal-actions">
                <button class="btn btn-secondary" @onclick="() => _showModal = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="Submit" disabled="@_saving">
                    @if (_saving) { <span class="spinner"></span> }
                    @(_editing ? "Guardar" : "Enviar Invitación")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<UserMessage>? _users;
    private bool _showModal;
    private bool _editing;
    private bool _saving;
    private UserMessage _model = new() { RoleName = "Visor" };

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        try { var r = await GrpcClient.GetUsersAsync(new Empty()); _users = r.Users.ToList(); } catch { }
    }

    private void OpenInvite() { _editing = false; _model = new UserMessage { RoleName = "Visor", IsActive = true, TenantId = State.ActiveTenantId }; _showModal = true; }
    private void Edit(UserMessage u) { _editing = true; _model = new UserMessage { Id = u.Id, Name = u.Name, Email = u.Email, RoleName = u.RoleName, IsActive = u.IsActive, TenantId = u.TenantId }; _showModal = true; }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_model.Email) || string.IsNullOrWhiteSpace(_model.Name)) return;
        _saving = true; StateHasChanged();
        try
        {
            if (_editing) { var r = await GrpcClient.UpdateUserAsync(_model); if (r.Success) await Load(); }
            else { var r = await GrpcClient.InviteUserAsync(new InviteUserRequest { Email = _model.Email, Name = _model.Name, RoleName = _model.RoleName, TenantId = State.ActiveTenantId }); if (r.Success) await Load(); }
            _showModal = false;
        }
        catch { }
        finally { _saving = false; StateHasChanged(); }
    }

    private async Task Delete(UserMessage u)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Eliminar acceso de {u.Name}?")) return;
        try { await GrpcClient.DeleteUserAsync(new DeleteEntityRequest { Id = u.Id, TenantId = State.ActiveTenantId }); await Load(); } catch { }
    }
}
