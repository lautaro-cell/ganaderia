@using GestorGanadero.Services.Common.Contracts
@using GestorGanadero.Services.Catalog.Contracts
@using GestorGanadero.Client.Services
@inject AppStateContainer State
@inject CatalogService.CatalogServiceClient GrpcClient
@inject IJSRuntime JS

<div class="split-view">
    <div class="master-panel">
        <div style="padding:16px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border);">
            <h3 style="font-size:1rem; font-weight:600;">Lotes</h3>
            <button class="btn btn-primary btn-sm" @onclick="New"><span class="material-icons" style="font-size:16px;">add</span> Nuevo</button>
        </div>
        <div style="flex:1; overflow-y:auto;">
            @if (_items == null) { <div class="loading-container"><div class="spinner"></div></div> }
            else { @foreach (var l in _items) {
                <div class="master-item @(_sel?.Id == l.Id ? "selected" : "")" @onclick="() => Sel(l)">
                    <div><div style="font-size:0.875rem; font-weight:500;">@l.Name</div><div style="font-size:0.75rem; color:var(--text-muted);">@l.FieldName</div></div>
                </div>
            }}
        </div>
    </div>
    <div class="detail-panel">
        @if (_sel == null) { <div class="empty-state"><span class="material-icons">grid_view</span><p>Selecciona o crea un lote.</p></div> }
        else {
            <h3 style="margin-bottom:24px;">@(string.IsNullOrEmpty(_sel.Id) ? "Nuevo" : "Editar") Lote</h3>
            <div class="form-group"><label>Nombre</label><input type="text" @bind="_sel.Name" class="form-control" /></div>
            <div class="form-group"><label>Campo</label>
                <select @bind="_sel.FieldId" class="form-control"><option value="">Seleccione...</option>@if(_fields!=null){@foreach(var f in _fields){<option value="@f.Id">@f.Name</option>}}</select>
            </div>
            <div class="form-group"><label>Actividades Permitidas</label>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; background:var(--surface-2); padding:12px; border-radius:var(--radius-md); border:1px solid var(--border);">
                    @if (_acts != null) { @foreach (var a in _acts) {
                        <label class="checkbox-group"><input type="checkbox" checked="@_sel.ActivityIds.Contains(a.Id)" @onchange="e => ToggleAct(a.Id, e.Value)" /><span>@a.Name</span></label>
                    }}
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_msg)) { <div class="alert @(_ok?"alert-success":"alert-danger") mb-md" style="margin-bottom:16px;">@_msg</div> }
            <div class="flex gap-sm">
                @if (!string.IsNullOrEmpty(_sel.Id)) { <button class="btn btn-danger-outline" @onclick="Del">Eliminar</button> }
                <div style="flex:1;"></div>
                <button class="btn btn-primary" @onclick="Save" disabled="@_saving">@if(_saving){<span class="spinner"></span>} Guardar</button>
            </div>
        }
    </div>
</div>

@code {
    private List<LoteMessage>? _items;
    private List<FieldMessage>? _fields;
    private List<ActivityMessage>? _acts;
    private LoteMessage? _sel;
    private bool _saving; private string _msg = ""; private bool _ok;

    protected override async Task OnInitializedAsync() => await Load();
    private async Task Load() {
        if (string.IsNullOrEmpty(State.ActiveTenantId)) return;
        try { var l = await GrpcClient.GetLotesAsync(new GetLotesRequest { TenantId = State.ActiveTenantId }); _items = l.Lotes.ToList(); var f = await GrpcClient.GetFieldsAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId }); _fields = f.Fields.ToList(); var a = await GrpcClient.GetActivitiesAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId }); _acts = a.Activities.ToList(); } catch { }
    }
    private void New() { _sel = new LoteMessage { TenantId = State.ActiveTenantId }; _msg = ""; }
    private void Sel(LoteMessage l) { _sel = new LoteMessage { Id = l.Id, Name = l.Name, FieldId = l.FieldId, FieldName = l.FieldName, TenantId = l.TenantId }; _sel.ActivityIds.AddRange(l.ActivityIds); _msg = ""; }
    private void ToggleAct(string id, object? val) { if (_sel == null) return; if (val is bool b && b) { if (!_sel.ActivityIds.Contains(id)) _sel.ActivityIds.Add(id); } else _sel.ActivityIds.Remove(id); }
    private async Task Save() {
        if (_sel == null || string.IsNullOrWhiteSpace(_sel.Name)) return;
        _saving = true; _msg = ""; StateHasChanged();
        try { var r = string.IsNullOrEmpty(_sel.Id) ? await GrpcClient.CreateLoteAsync(_sel) : await GrpcClient.UpdateLoteAsync(_sel); if (r.Success) { _ok = true; _msg = "Guardado."; await Load(); } else { _ok = false; _msg = r.Message; } }
        catch (Exception ex) { _ok = false; _msg = $"Error: {ex.Message}"; }
        finally { _saving = false; StateHasChanged(); }
    }
    private async Task Del() {
        if (_sel == null || string.IsNullOrEmpty(_sel.Id)) return;
        if (!await JS.InvokeAsync<bool>("confirm", $"Eliminar lote '{_sel.Name}'?")) return;
        try { var r = await GrpcClient.DeleteLoteAsync(new DeleteEntityRequest { Id = _sel.Id, TenantId = State.ActiveTenantId }); if (r.Success) { _sel = null; await Load(); } } catch (Exception ex) { _ok = false; _msg = $"Error: {ex.Message}"; }
    }
}
