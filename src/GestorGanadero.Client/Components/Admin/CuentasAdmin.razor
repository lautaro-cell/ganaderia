@using GestorGanadero.Services.Catalog.Contracts
@using GestorGanadero.Services.Common.Contracts
@using GestorGanadero.Client.Services
@inject AppStateContainer State
@inject CatalogService.CatalogServiceClient GrpcClient
@inject IJSRuntime JS

<div class="flex flex-col gap-6">
    <!-- Breadcrumbs -->
    <div class="flex items-center gap-2 text-[11px] font-medium text-text-secondary uppercase tracking-widest opacity-60">
        <a href="/" class="hover:text-white transition-colors no-underline">Inicio</a>
        <span class="material-symbols-outlined text-[14px]">chevron_right</span>
        <span class="cursor-default">Administración</span>
        <span class="material-symbols-outlined text-[14px]">chevron_right</span>
        <span class="text-primary font-bold">Cuentas Contables</span>
    </div>

    <!-- Header -->
    <div class="flex flex-col gap-1">
        <h2 class="text-white text-2xl font-bold tracking-tight flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">account_balance</span>
            Gestión de Cuentas
        </h2>
        <p class="text-text-secondary text-sm">Administre el plan de cuentas utilizado para la generación automática de asientos.</p>
    </div>

    <!-- Table -->
    <div class="overflow-hidden rounded-xl border border-border-dark bg-surface-dark shadow-xl">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-darker/50 border-b border-border-dark">
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-text-secondary">Código / Nombre</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-text-secondary text-center">Plan asociado</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-text-secondary text-center">Tipo</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-text-secondary text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border-dark/30">
                    @if (_items == null)
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-10 text-center">
                                <div class="flex flex-col items-center gap-3">
                                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
                                    <p class="text-text-secondary text-sm font-medium">Cargando cuentas...</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else if (!_items.Any())
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-10 text-center text-text-disabled">No hay cuentas contables registradas.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var c in _items)
                        {
                            <tr class="hover:bg-white/5 transition-colors group">
                                <td class="px-6 py-4">
                                    <div class="flex flex-col">
                                        <span class="text-primary font-mono text-xs font-bold">@c.Code</span>
                                        <span class="text-white font-bold text-sm">@c.Name</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="px-2 py-1 rounded text-[10px] font-bold bg-surface-darker text-white border border-border-dark uppercase tracking-wider">@c.PlanName</span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="px-2 py-0.5 rounded text-[10px] font-black @(c.NormalType.ToLower() == "debe" ? "bg-emerald-500/10 text-emerald-400" : "bg-blue-500/10 text-blue-400") uppercase">@c.NormalType</span>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-1">
                                        <button class="p-2 hover:bg-surface-darker rounded-lg text-text-secondary hover:text-white transition-colors" @onclick="() => Sel(c)">
                                            <span class="material-symbols-outlined text-lg">edit</span>
                                        </button>
                                        <button class="p-2 hover:bg-red-500/10 rounded-lg text-text-secondary hover:text-red-400 transition-colors" @onclick="() => Del(c)">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Create/Edit Form Section -->
    <div class="mt-4 flex flex-col gap-4">
        <h3 class="text-white text-lg font-bold flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">@(string.IsNullOrEmpty(_sel?.Id) ? "add_circle" : "edit_square")</span>
            @(string.IsNullOrEmpty(_sel?.Id) ? "Crear Cuenta" : "Editar Cuenta")
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <input type="text" @bind="_sel.Code" class="w-full bg-surface-darker border border-border-dark rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-primary transition-colors font-mono" placeholder="Código (ej: 1.1.01)" />
            <input type="text" @bind="_sel.Name" class="w-full bg-surface-darker border border-border-dark rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-primary transition-colors" placeholder="Nombre de la cuenta" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="relative">
                <select @bind="_sel.PlanId" class="w-full bg-surface-darker border border-border-dark rounded-xl px-4 h-[46px] text-sm text-white focus:outline-none focus:border-primary transition-colors appearance-none cursor-pointer">
                    <option value="">Seleccione un plan...</option>
                    @if (_plans != null)
                    {
                        @foreach (var p in _plans)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    }
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-text-secondary pointer-events-none">expand_more</span>
            </div>

            <div class="relative">
                <select @bind="_sel.NormalType" class="w-full bg-surface-darker border border-border-dark rounded-xl px-4 h-[46px] text-sm text-white focus:outline-none focus:border-primary transition-colors appearance-none cursor-pointer">
                    <option value="Debe">Saldo Normal: DEBE</option>
                    <option value="Haber">Saldo Normal: HABER</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-text-secondary pointer-events-none">expand_more</span>
            </div>
        </div>

        <button class="flex items-center justify-center gap-2 w-full h-12 bg-primary hover:bg-red-700 transition-colors text-white font-bold rounded-xl shadow-lg shadow-primary/20 disabled:opacity-50" 
                @onclick="Save" disabled="@_saving">
            @if (_saving)
            {
                <div class="animate-spin rounded-full h-5 w-5 border-b-2 border-white mr-2"></div>
            }
            else
            {
                <span class="material-symbols-outlined">save</span>
            }
            <span>@(string.IsNullOrEmpty(_sel.Id) ? "Crear Cuenta" : "Guardar Cambios")</span>
        </button>

        @if (!string.IsNullOrEmpty(_sel.Id))
        {
            <button class="text-text-secondary hover:text-white text-xs font-bold uppercase tracking-widest transition-colors mt-1" @onclick="CancelEdit">
                Cancelar Edición
            </button>
        }
    </div>
</div>

@code {
    private List<AccountMessage>? _items;
    private List<PlanCuentaMessage>? _plans;
    private AccountMessage _sel = new() { IsActive = true, NormalType = "Debe" };
    private bool _saving;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load() {
        if (string.IsNullOrEmpty(State.ActiveTenantId)) return;
        try {
            var r = await GrpcClient.GetAccountsAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId });
            _items = r.Accounts.ToList();
            var p = await GrpcClient.GetPlanesAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId });
            _plans = p.Planes.ToList();
            _sel.TenantId = State.ActiveTenantId;
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private void Sel(AccountMessage a) => _sel = new AccountMessage { Id = a.Id, Code = a.Code, Name = a.Name, PlanId = a.PlanId, PlanName = a.PlanName, NormalType = a.NormalType, IsActive = a.IsActive, TenantId = State.ActiveTenantId };

    private void CancelEdit() => _sel = new AccountMessage { IsActive = true, NormalType = "Debe", TenantId = State.ActiveTenantId };

    private async Task Save() {
        if (string.IsNullOrWhiteSpace(_sel.Code) || string.IsNullOrWhiteSpace(_sel.Name) || string.IsNullOrEmpty(_sel.PlanId)) return;
        _saving = true; StateHasChanged();
        try {
            if (string.IsNullOrEmpty(_sel.Id)) await GrpcClient.CreateAccountAsync(_sel);
            else await GrpcClient.UpdateAccountAsync(_sel);
            CancelEdit();
            await Load();
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
        finally { _saving = false; StateHasChanged(); }
    }

    private async Task Del(AccountMessage a) {
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Eliminar cuenta '{a.Name}'?")) return;
        try {
            await GrpcClient.DeleteAccountAsync(new DeleteEntityRequest { Id = a.Id, TenantId = State.ActiveTenantId });
            await Load();
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
    }
}
