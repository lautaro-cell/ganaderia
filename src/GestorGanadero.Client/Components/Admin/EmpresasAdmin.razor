@using GestorGanadero.Services.Common.Contracts
@using GestorGanadero.Services.Identity.Contracts
@using GestorGanadero.Client.Services
@using Google.Protobuf.WellKnownTypes
@inject AppStateContainer State
@inject IdentityService.IdentityServiceClient IdentityClient
@inject IJSRuntime JS

<div class="flex flex-col gap-6">
    <!-- Breadcrumbs -->
    <div class="flex items-center gap-2 text-[11px] font-medium text-text-secondary uppercase tracking-widest opacity-60">
        <a href="/" class="hover:text-white transition-colors no-underline">Inicio</a>
        <span class="material-symbols-outlined text-[14px]">chevron_right</span>
        <span class="cursor-default">Administración</span>
        <span class="material-symbols-outlined text-[14px]">chevron_right</span>
        <span class="text-primary font-bold">Empresas</span>
    </div>

    <!-- Header -->
    <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-primary text-2xl">business</span>
        <h2 class="text-white text-xl font-bold">Gestión de Empresas</h2>
    </div>
    <p class="text-text-secondary text-sm -mt-4">Administre los establecimientos y sus credenciales de integración con GestorMax.</p>

    <!-- Table -->
    <div class="bg-background-main border border-border-dark rounded-2xl overflow-hidden shadow-xl shadow-black/20">
        <table class="w-full text-left text-sm">
            <thead class="bg-surface-darker text-text-secondary uppercase text-[10px] tracking-widest border-b border-border-dark">
                <tr>
                    <th class="px-6 py-4">Nombre</th>
                    <th class="px-6 py-4 text-center">Gestor DB ID</th>
                    <th class="px-6 py-4 text-right">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border-dark/30">
                @if (_tenants == null)
                {
                    <tr>
                        <td colspan="3" class="px-6 py-12 text-center">
                            <div class="flex flex-col items-center gap-3">
                                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
                                <p class="text-text-secondary text-sm font-medium">Cargando empresas...</p>
                            </div>
                        </td>
                    </tr>
                }
                else if (!_tenants.Any())
                {
                    <tr>
                        <td colspan="3" class="px-6 py-12 text-center text-text-disabled">No hay empresas registradas.</td>
                    </tr>
                }
                else
                {
                    @foreach (var t in _tenants)
                    {
                        <tr class="hover:bg-white/5 transition-colors group">
                            <td class="px-6 py-4">
                                <span class="text-white font-bold text-sm">@t.Name</span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="font-mono text-xs text-text-secondary bg-surface-darker px-3 py-1 rounded border border-border-dark/50">
                                    @(string.IsNullOrEmpty(t.GestorMaxDatabaseId) ? "No configurado" : t.GestorMaxDatabaseId)
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <button class="flex items-center gap-1 px-3 py-1.5 rounded-lg bg-surface-darker border border-border-dark text-text-secondary hover:text-white hover:border-text-secondary transition-all text-xs font-bold" 
                                            @onclick="() => Edit(t)">
                                        <span class="material-symbols-outlined text-sm">settings</span>
                                        Configurar
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (_showModal)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm" @onclick="() => _showModal = false">
            <div class="w-full max-w-md bg-surface-dark border border-border-dark rounded-2xl shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-200" @onclick:stopPropagation>
                <div class="flex items-center justify-between px-6 py-4 border-b border-border-dark bg-surface-darker/50">
                    <h3 class="text-lg font-bold text-white">Configurar Empresa</h3>
                    <button class="text-text-secondary hover:text-white transition-colors" @onclick="() => _showModal = false">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>
                
                <div class="p-6 flex flex-col gap-5">
                    <div class="flex flex-col gap-2">
                        <label class="text-xs font-bold text-text-secondary uppercase tracking-wider">Nombre</label>
                        <input type="text" @bind="_model.Name" class="w-full bg-surface-darker border border-border-dark rounded-lg px-4 py-2.5 text-sm text-white focus:outline-none focus:border-primary" />
                    </div>
                    
                    <div class="flex flex-col gap-2">
                        <label class="text-xs font-bold text-text-secondary uppercase tracking-wider">GestorMax Database ID</label>
                        <input type="text" @bind="_model.GestorMaxDatabaseId" class="w-full bg-surface-darker border border-border-dark rounded-lg px-4 py-2.5 text-sm text-white focus:outline-none focus:border-primary font-mono" placeholder="Ej: 101" />
                    </div>
                    
                    <div class="flex flex-col gap-2">
                        <label class="text-xs font-bold text-text-secondary uppercase tracking-wider">GestorMax API Key</label>
                        <div class="relative">
                            <input type="@(_showKey ? "text" : "password")" @bind="_model.GestorMaxApiKey" class="w-full bg-surface-darker border border-border-dark rounded-lg px-4 py-2.5 text-sm text-white focus:outline-none focus:border-primary font-mono pr-10" placeholder="••••••••••••••••" />
                            <button class="absolute right-3 top-1/2 -translate-y-1/2 text-text-disabled hover:text-white transition-colors" @onclick="() => _showKey = !_showKey">
                                <span class="material-symbols-outlined text-sm">@(_showKey ? "visibility_off" : "visibility")</span>
                            </button>
                        </div>
                        <p class="text-[10px] text-text-disabled italic mt-1">La clave se encriptará de forma segura antes de guardarse.</p>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_msg))
                {
                    <div class="mx-6 mb-4 p-3 rounded-lg @(_ok ? "bg-green-500/10 text-green-400 border border-green-500/20" : "bg-red-500/10 text-red-400 border border-red-500/20") text-xs">
                        @_msg
                    </div>
                }

                <div class="px-6 py-4 bg-surface-darker/50 border-t border-border-dark flex justify-end gap-3">
                    <button class="px-5 py-2 rounded-lg text-sm font-bold text-text-secondary hover:text-white transition-colors" @onclick="() => _showModal = false">
                        Cancelar
                    </button>
                    <button class="flex items-center justify-center min-w-[120px] px-5 py-2 rounded-lg text-sm font-bold text-white bg-primary hover:bg-red-700 transition-colors shadow-lg shadow-primary/20 disabled:opacity-50" 
                            @onclick="Save" disabled="@_saving">
                        @if (_saving)
                        {
                            <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-white mr-2"></div>
                        }
                        <span>Guardar Cambios</span>
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<TenantMessage>? _tenants;
    private TenantMessage _model = new();
    private bool _showModal;
    private bool _saving;
    private bool _showKey;
    private string _msg = "";
    private bool _ok;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        try
        {
            var res = await IdentityClient.GetAllTenantsAsync(new Empty());
            _tenants = res.Tenants.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading tenants: {ex.Message}");
        }
    }

    private void Edit(TenantMessage t)
    {
        _model = new TenantMessage { 
            Id = t.Id, 
            Name = t.Name, 
            GestorMaxDatabaseId = t.GestorMaxDatabaseId,
            GestorMaxApiKey = "" // Don't send encrypted key to client
        };
        _msg = "";
        _showKey = false;
        _showModal = true;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_model.Name)) return;
        
        _saving = true;
        _msg = "Guardando...";
        _ok = true;
        StateHasChanged();

        try
        {
            var res = await IdentityClient.UpdateTenantAsync(_model);
            if (res.Success)
            {
                _msg = "Empresa actualizada.";
                _ok = true;
                await Load();
                await Task.Delay(1000);
                _showModal = false;
            }
            else
            {
                _msg = res.Message;
                _ok = false;
            }
        }
        catch (Exception ex)
        {
            _msg = $"Error: {ex.Message}";
            _ok = false;
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }
}
