@using GestorGanadero.Services.Catalog.Contracts
@using GestorGanadero.Services.Common.Contracts
@using GestorGanadero.Client.Services
@using GestorGanadero.Client.Catalog
@inject AppStateContainer State
@inject CatalogService.CatalogServiceClient GrpcClient
@inject CatalogCacheService CatalogCache
@inject IJSRuntime JS

<div class="flex flex-col gap-6">
    <!-- Breadcrumbs -->
    <div class="flex items-center gap-2 text-[11px] font-medium text-text-secondary uppercase tracking-widest opacity-60">
        <a href="/" class="hover:text-white transition-colors no-underline">Inicio</a>
        <span class="material-symbols-outlined text-[14px]">chevron_right</span>
        <span class="cursor-default">Administración</span>
        <span class="material-symbols-outlined text-[14px]">chevron_right</span>
        <span class="text-primary font-bold">Tipos de Evento</span>
    </div>

    <!-- Header -->
    <div class="flex flex-col gap-1">
        <h2 class="text-white text-2xl font-bold tracking-tight flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">settings_applications</span>
            Gestión de Tipos de Evento
        </h2>
        <p class="text-text-secondary text-sm">Configure las plantillas de eventos y sus reglas de negocio asociadas.</p>
    </div>

    <!-- Table -->
    <div class="overflow-hidden rounded-xl border border-border-dark bg-surface-dark shadow-xl">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-darker/50 border-b border-border-dark">
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-text-secondary">Código / Nombre</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-text-secondary text-center">Configuración</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-text-secondary">Cuentas (Debe/Haber)</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-text-secondary text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border-dark/30">
                    @if (_items == null)
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-10 text-center">
                                <div class="flex flex-col items-center gap-3">
                                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
                                    <p class="text-text-secondary text-sm font-medium">Cargando tipos de evento...</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else if (!_items.Any())
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-10 text-center text-text-disabled">No hay tipos de evento registrados.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var e in _items)
                        {
                            <tr class="hover:bg-white/5 transition-colors group">
                                <td class="px-6 py-4">
                                    <div class="flex flex-col">
                                        <span class="text-primary font-mono text-xs font-bold">@e.Code</span>
                                        <span class="text-white font-bold text-sm">@e.Name</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex flex-wrap justify-center gap-2">
                                        @if (e.RequiresOriginDestination)
                                        {
                                            <span class="px-2 py-0.5 rounded text-[9px] font-black bg-blue-500/10 text-blue-400 border border-blue-500/20 uppercase">Origen/Destino</span>
                                        }
                                        @if (e.RequiresDestinationField)
                                        {
                                            <span class="px-2 py-0.5 rounded text-[9px] font-black bg-purple-500/10 text-purple-400 border border-purple-500/20 uppercase">Campo Destino</span>
                                        }
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-2 font-mono text-[10px]">
                                        <span class="text-emerald-400">@e.DebitAccountCode</span>
                                        <span class="text-text-disabled">/</span>
                                        <span class="text-red-400">@e.CreditAccountCode</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-1">
                                        <button class="p-2 hover:bg-surface-darker rounded-lg text-text-secondary hover:text-white transition-colors" @onclick="() => Sel(e)">
                                            <span class="material-symbols-outlined text-lg">edit</span>
                                        </button>
                                        <button class="p-2 hover:bg-red-500/10 rounded-lg text-text-secondary hover:text-red-400 transition-colors" @onclick="() => Del(e)">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Create/Edit Form Section -->
    <div class="mt-4 flex flex-col gap-4">
        <h3 class="text-white text-lg font-bold flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">@(string.IsNullOrEmpty(_sel?.Id) ? "add_circle" : "edit_square")</span>
            @(string.IsNullOrEmpty(_sel?.Id) ? "Crear Tipo de Evento" : "Editar Tipo de Evento")
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <input type="text" @bind="_sel.Code" class="w-full bg-surface-darker border border-border-dark rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-primary transition-colors" placeholder="Código (ej: VENTA, TRASLADO)" />
            <input type="text" @bind="_sel.Name" class="w-full bg-surface-darker border border-border-dark rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-primary transition-colors" placeholder="Nombre descriptivo" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <input type="text" @bind="_sel.DebitAccountCode" class="w-full bg-surface-darker border border-border-dark rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-primary transition-colors font-mono" placeholder="Código cuenta DEBE" />
            <input type="text" @bind="_sel.CreditAccountCode" class="w-full bg-surface-darker border border-border-dark rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-primary transition-colors font-mono" placeholder="Código cuenta HABER" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <label class="flex items-center gap-3 px-4 py-3 bg-surface-darker rounded-xl border border-border-dark cursor-pointer group">
                <input type="checkbox" @bind="_sel.RequiresOriginDestination" class="w-4 h-4 rounded border-border-dark bg-surface-dark text-primary focus:ring-primary focus:ring-offset-0" />
                <span class="text-sm font-medium text-text-secondary group-hover:text-white transition-colors">Requiere Origen/Destino</span>
            </label>
            <label class="flex items-center gap-3 px-4 py-3 bg-surface-darker rounded-xl border border-border-dark cursor-pointer group">
                <input type="checkbox" @bind="_sel.RequiresDestinationField" class="w-4 h-4 rounded border-border-dark bg-surface-dark text-primary focus:ring-primary focus:ring-offset-0" />
                <span class="text-sm font-medium text-text-secondary group-hover:text-white transition-colors">Requiere Campo Destino</span>
            </label>
        </div>

        <button class="flex items-center justify-center gap-2 w-full h-12 bg-primary hover:bg-red-700 transition-colors text-white font-bold rounded-xl shadow-lg shadow-primary/20 disabled:opacity-50" 
                @onclick="Save" disabled="@_saving">
            @if (_saving)
            {
                <div class="animate-spin rounded-full h-5 w-5 border-b-2 border-white"></div>
            }
            else
            {
                <span class="material-symbols-outlined">save</span>
            }
            <span>@(string.IsNullOrEmpty(_sel.Id) ? "Crear Tipo de Evento" : "Guardar Cambios")</span>
        </button>

        @if (!string.IsNullOrEmpty(_sel.Id))
        {
            <button class="text-text-secondary hover:text-white text-xs font-bold uppercase tracking-widest transition-colors mt-1" @onclick="CancelEdit">
                Cancelar Edición
            </button>
        }
    </div>
</div>

@code {
    private List<EventTypeMessage>? _items;
    private List<ErpAccountMessage>? _erpAccounts;
    private List<ActivityMessage>? _activities;
    private EventTypeMessage _sel = new() { IsActive = true };
    private bool _saving;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        if (string.IsNullOrEmpty(State.ActiveTenantId)) return;
        try {
            var r = await GrpcClient.GetEventTypesAsync(new GetCatalogRequest { TenantId = State.ActiveTenantId });
            _items = r.EventTypes.ToList();
            _sel.TenantId = State.ActiveTenantId;
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private void Sel(EventTypeMessage e) => _sel = new EventTypeMessage { Id = e.Id, Code = e.Code, Name = e.Name, DebitAccountCode = e.DebitAccountCode, CreditAccountCode = e.CreditAccountCode, RequiresOriginDestination = e.RequiresOriginDestination, RequiresDestinationField = e.RequiresDestinationField, IsActive = e.IsActive, TenantId = State.ActiveTenantId };

    private void CancelEdit() => _sel = new EventTypeMessage { IsActive = true, TenantId = State.ActiveTenantId };

    private async Task Save() {
        if (string.IsNullOrWhiteSpace(_sel.Code) || string.IsNullOrWhiteSpace(_sel.Name)) return;
        _saving = true; StateHasChanged();
        try {
            if (string.IsNullOrEmpty(_sel.Id)) await GrpcClient.CreateEventTypeAsync(_sel);
            else await GrpcClient.UpdateEventTypeAsync(_sel);
            CancelEdit();
            await Load();
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
        finally { _saving = false; StateHasChanged(); }
    }

    private async Task Del(EventTypeMessage e) {
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Eliminar tipo de evento '{e.Name}'?")) return;
        try {
            await GrpcClient.DeleteEventTypeAsync(new DeleteEntityRequest { Id = e.Id, TenantId = State.ActiveTenantId });
            await Load();
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
    }
}
