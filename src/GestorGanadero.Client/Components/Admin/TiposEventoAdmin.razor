@using GestorGanadero.Services.Catalog.Contracts
@using GestorGanadero.Services.Common.Contracts
@using GestorGanadero.Client.Services
@using GestorGanadero.Client.Catalog
@inject AppStateContainer State
@inject CatalogService.CatalogServiceClient GrpcClient
@inject CatalogCacheService CatalogCache
@inject IJSRuntime JS

<div class="flex flex-col gap-6">
    <!-- Header -->
    <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-primary text-2xl">event</span>
        <h2 class="text-white text-xl font-bold">Gestión de Tipos de Evento</h2>
    </div>
    <p class="text-text-secondary text-sm -mt-4">Configuración de eventos con sus cuentas contables asociadas.</p>

    @if (_erpError != null)
    {
        <div class="bg-yellow-900/30 border border-yellow-700 rounded-xl px-4 py-3 text-yellow-300 text-sm flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">warning</span>
            @_erpError — Las cuentas ERP no están disponibles. Ingrese los códigos manualmente.
        </div>
    }

    <!-- Table -->
    <div class="bg-background-main border border-border-dark rounded-2xl overflow-hidden shadow-xl shadow-black/20">
        <table class="w-full text-left text-sm">
            <thead class="bg-surface-darker text-text-secondary uppercase text-[10px] tracking-widest">
                <tr>
                    <th class="px-6 py-4">Código</th>
                    <th class="px-6 py-4">Nombre</th>
                    <th class="px-6 py-4">Cuenta DEBE</th>
                    <th class="px-6 py-4">Cuenta HABER</th>
                    <th class="px-6 py-4 text-right">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border-dark">
                @if (_items == null)
                {
                    <tr>
                        <td colspan="5" class="px-6 py-8 text-center text-text-secondary">
                            <div class="animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-primary mx-auto"></div>
                        </td>
                    </tr>
                }
                else if (!_items.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-8 text-center text-text-secondary">No hay tipos de evento registrados</td>
                    </tr>
                }
                else
                {
                    @foreach (var e in _items)
                    {
                        <tr class="hover:bg-surface-dark transition-colors">
                            <td class="px-6 py-4 text-primary font-mono font-bold">@e.Code</td>
                            <td class="px-6 py-4 text-white font-bold">@e.Name</td>
                            <td class="px-6 py-4 text-text-body font-mono">@e.DebitAccountCode</td>
                            <td class="px-6 py-4 text-text-body font-mono">@e.CreditAccountCode</td>
                            <td class="px-6 py-4 text-right">
                                <button class="p-1.5 text-text-secondary hover:text-white rounded-lg transition-colors" title="Editar" @onclick="() => Sel(e)">
                                    <span class="material-symbols-outlined text-[18px]">edit</span>
                                </button>
                                <button class="p-1.5 text-text-secondary hover:text-red-400 rounded-lg transition-colors" title="Eliminar" @onclick="() => Del(e)">
                                    <span class="material-symbols-outlined text-[18px]">delete</span>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Create/Edit Form -->
    <div class="bg-background-main rounded-2xl border border-border-dark p-6">
        <h3 class="text-white font-bold flex items-center gap-2 mb-6">
            <span class="material-symbols-outlined text-primary">add_circle</span>
            @(string.IsNullOrEmpty(_sel?.Id) ? "Crear Tipo de Evento" : "Editar Tipo de Evento")
        </h3>

        @if (_validationError != null)
        {
            <div class="mb-4 bg-red-900/30 border border-red-700 rounded-xl px-4 py-3 text-red-300 text-sm">
                @_validationError
            </div>
        }

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <input type="text" @bind="_sel.Code"
                   class="w-full bg-[#271c1c] border border-[#543b3b] rounded-xl px-4 py-3 text-white focus:ring-primary outline-none"
                   placeholder="Código (ej: VENTA)" />

            <input type="text" @bind="_sel.Name"
                   class="w-full bg-[#271c1c] border border-[#543b3b] rounded-xl px-4 py-3 text-white focus:ring-primary outline-none"
                   placeholder="Nombre descriptivo" />

            <!-- context7 /dotnet/blazor-samples: <select> con @bind para dropdowns poblados desde servicio -->
            @if (_erpAccounts != null && _erpAccounts.Any())
            {
                <div class="flex flex-col gap-1">
                    <label class="text-text-secondary text-xs uppercase tracking-wider">Cuenta DEBE</label>
                    <select @bind="_sel.DebitAccountCode"
                            class="w-full bg-[#271c1c] border border-[#543b3b] rounded-xl px-4 py-3 text-white focus:ring-primary outline-none cursor-pointer">
                        <option value="">Seleccionar cuenta DEBE...</option>
                        @foreach (var acc in _erpAccounts)
                        {
                            <option value="@acc.Code">@acc.Code — @acc.Name</option>
                        }
                    </select>
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-text-secondary text-xs uppercase tracking-wider">Cuenta HABER</label>
                    <select @bind="_sel.CreditAccountCode"
                            class="w-full bg-[#271c1c] border border-[#543b3b] rounded-xl px-4 py-3 text-white focus:ring-primary outline-none cursor-pointer">
                        <option value="">Seleccionar cuenta HABER...</option>
                        @foreach (var acc in _erpAccounts)
                        {
                            <option value="@acc.Code">@acc.Code — @acc.Name</option>
                        }
                    </select>
                </div>
            }
            else
            {
                <input type="text" @bind="_sel.DebitAccountCode"
                       class="w-full bg-[#271c1c] border border-[#543b3b] rounded-xl px-4 py-3 text-white focus:ring-primary outline-none"
                       placeholder="Cuenta DEBE (código manual)..." />
                <input type="text" @bind="_sel.CreditAccountCode"
                       class="w-full bg-[#271c1c] border border-[#543b3b] rounded-xl px-4 py-3 text-white focus:ring-primary outline-none"
                       placeholder="Cuenta HABER (código manual)..." />
            }

            <label class="flex items-center gap-3 cursor-pointer p-3 rounded-xl border border-border-dark bg-[#222222]">
                <input type="checkbox" @bind="_sel.RequiresOriginDestination"
                       class="w-5 h-5 rounded bg-[#1A1A1A] border-[#595959] text-primary" />
                <span class="text-white text-sm">Requiere Origen/Destino</span>
            </label>

            <label class="flex items-center gap-3 cursor-pointer p-3 rounded-xl border border-border-dark bg-[#222222]">
                <input type="checkbox" @bind="_sel.RequiresDestinationField"
                       class="w-5 h-5 rounded bg-[#1A1A1A] border-[#595959] text-primary" />
                <span class="text-white text-sm">Requiere Campo Destino</span>
            </label>

            <!-- Actividades aplicables (Tarea 7.3) -->
            <div class="md:col-span-2 flex flex-col gap-2">
                <label class="text-text-secondary text-xs uppercase tracking-wider font-bold">Actividades Aplicables</label>
                @if (_activities != null && _activities.Any())
                {
                    <div class="flex flex-wrap gap-2 p-3 bg-[#1A1A1A] rounded-xl border border-border-dark">
                        @foreach (var act in _activities)
                        {
                            var isSel = _selectedActivityIds.Contains(act.Id);
                            <button type="button"
                                    class="px-3 py-1.5 rounded-lg text-xs font-bold border transition-all @(isSel ? "bg-primary/10 border-primary/40 text-primary" : "bg-[#222222] border-[#543b3b] text-text-secondary hover:border-text-secondary")"
                                    @onclick="() => ToggleActivity(act.Id)">
                                @if (isSel) { <span class="material-symbols-outlined text-[13px] mr-0.5">check</span> }
                                @act.Name
                            </button>
                        }
                    </div>
                }
                else
                {
                    <p class="text-text-disabled text-xs px-3">No hay actividades disponibles.</p>
                }
            </div>

            <button class="md:col-span-2 w-full bg-primary hover:bg-red-700 text-white font-bold py-3 rounded-xl transition-all shadow-lg shadow-primary/20 flex items-center justify-center gap-2"
                    @onclick="Save">
                <span class="material-symbols-outlined text-[20px]">save</span>
                @(string.IsNullOrEmpty(_sel.Id) ? "Crear" : "Actualizar") Tipo de Evento
            </button>
        </div>
    </div>
</div>

@code {
    private List<EventTypeMessage>? _items;
    private List<ErpAccountMessage>? _erpAccounts;
    private List<ActivityMessage>? _activities;
    private EventTypeMessage _sel = new() { IsActive = true };
    private HashSet<string> _selectedActivityIds = new();
    private string? _erpError;
    private string? _validationError;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        if (string.IsNullOrEmpty(State.ActiveTenantId)) return;

        var req = new GetCatalogRequest { TenantId = State.ActiveTenantId };
        var r = await GrpcClient.GetEventTypesAsync(req);
        _items = r.EventTypes.ToList();
        _sel.TenantId = State.ActiveTenantId;

        try
        {
            var actR = await GrpcClient.GetActivitiesAsync(req);
            _activities = actR.Activities.ToList();
        }
        catch { _activities = new(); }

        try
        {
            var erpR = await GrpcClient.GetErpAccountsAsync(req);
            _erpAccounts = erpR.Accounts.ToList();
            _erpError = null;
        }
        catch
        {
            _erpAccounts = null;
            _erpError = "No se pudo conectar con GestorMax";
        }
    }

    private void ToggleActivity(string id) { if (!_selectedActivityIds.Remove(id)) _selectedActivityIds.Add(id); }

    private void Sel(EventTypeMessage e)
    {
        _validationError = null;
        _sel = new EventTypeMessage
        {
            Id = e.Id, Code = e.Code, Name = e.Name,
            DebitAccountCode = e.DebitAccountCode, CreditAccountCode = e.CreditAccountCode,
            RequiresOriginDestination = e.RequiresOriginDestination,
            RequiresDestinationField = e.RequiresDestinationField,
            IsActive = e.IsActive, TenantId = State.ActiveTenantId
        };
        _selectedActivityIds = new HashSet<string>(e.ActivityIds);
    }

    private async Task Save()
    {
        _validationError = null;

        // Validación cliente (Tarea 2.4)
        if (string.IsNullOrWhiteSpace(_sel.Code))
        { _validationError = "El código es obligatorio."; return; }
        if (string.IsNullOrWhiteSpace(_sel.DebitAccountCode))
        { _validationError = "La cuenta DEBE es obligatoria."; return; }
        if (string.IsNullOrWhiteSpace(_sel.CreditAccountCode))
        { _validationError = "La cuenta HABER es obligatoria."; return; }
        if (string.Equals(_sel.DebitAccountCode.Trim(), _sel.CreditAccountCode.Trim(), StringComparison.OrdinalIgnoreCase))
        { _validationError = "La cuenta DEBE y HABER no pueden ser iguales."; return; }

        _sel.ActivityIds.Clear();
        _sel.ActivityIds.AddRange(_selectedActivityIds);

        if (string.IsNullOrEmpty(_sel.Id))
            await GrpcClient.CreateEventTypeAsync(_sel);
        else
            await GrpcClient.UpdateEventTypeAsync(_sel);

        CatalogCache.InvalidateTenant(State.ActiveTenantId);
        _sel = new EventTypeMessage { IsActive = true, TenantId = State.ActiveTenantId };
        _selectedActivityIds = new HashSet<string>();
        await Load();
    }

    private async Task Del(EventTypeMessage e)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "¿Eliminar este tipo de evento?")) return;
        await GrpcClient.DeleteEventTypeAsync(new DeleteEntityRequest { Id = e.Id, TenantId = State.ActiveTenantId });
        CatalogCache.InvalidateTenant(State.ActiveTenantId);
        await Load();
    }
}
