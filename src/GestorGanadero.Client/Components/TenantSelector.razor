@using GestorGanadero.Client.Services
@using GestorGanadero.Services.Common.Contracts
@using GestorGanadero.Services.Identity.Contracts
@using GestorGanadero.Services.Catalog.Contracts
@using GestorGanadero.Services.Operations.Contracts
@using GestorGanadero.Services.Reporting.Contracts
@using GestorGanadero.Services.Sync.Contracts
@inject IdentityService.IdentityServiceClient Client
@inject AppState State
@implements IDisposable

<div class="tenant-selector">
    <select @onchange="OnTenantChanged" value="@State.SelectedTenantId">
        <option value="">Seleccionar Empresa...</option>
        @foreach (var tenant in _tenants)
        {
            <option value="@tenant.Id">@tenant.Name</option>
        }
    </select>
</div>

@code {
    private List<TenantMessage> _tenants = new();

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;
        try
        {
            var response = await Client.GetAvailableTenantsAsync(new Google.Protobuf.WellKnownTypes.Empty());
            _tenants = response.Tenants.ToList();
            
            if (string.IsNullOrEmpty(State.SelectedTenantId) && _tenants.Any())
            {
                State.SelectedTenantId = _tenants.First().Id;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading tenants: {ex.Message}");
        }
    }

    private void OnTenantChanged(ChangeEventArgs e)
    {
        State.SelectedTenantId = e.Value?.ToString();
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }
}

